# =============================================================================
# .env.example — Vorlage für lokale Umgebungsvariablen (Alles-Wurst 2.0)
# =============================================================================
# Anleitung:
#   1. Diese Datei nach .env kopieren:  cp .env.example .env
#      (Windows PowerShell: Copy-Item .env.example .env)
#   2. Werte bei Bedarf anpassen (lokale Entwicklung: Standardwerte reichen)
#   3. .env wird von Git ignoriert — niemals committen
#
# Ausführliche Dokumentation: docs/DATENBANK_SETUP.md
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL — Verbindung für Prisma
# -----------------------------------------------------------------------------
# Format: postgresql://BENUTZER:PASSWORT@HOST:PORT/DATENBANK?schema=SCHEMA
#
# Muss zu docker-compose.yml passen (POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB)
DATABASE_URL="postgresql://alles_wurst:alles_wurst_dev@localhost:5432/alles_wurst?schema=public"

# -----------------------------------------------------------------------------
# Admin — provisorischer Token für den Rezeptgenerator-Adminmodus (Prototyp)
# -----------------------------------------------------------------------------
# Muss mit dem Token übereinstimmen, den Admins im Browser eingeben.
# In Produktion durch echte Auth ersetzen — niemals committen oder leaken.
RECIPE_ADMIN_TOKEN="dev-admin-token-change-in-production"

# -----------------------------------------------------------------------------
# Auth — signiertes Session-Cookie (Registrierung & Login)
# -----------------------------------------------------------------------------
# Mindestens 32 Zeichen — in Produktion durch einen starken Zufallswert ersetzen.
AUTH_SESSION_SECRET="dev-auth-session-secret-change-in-production-min-32-chars"

# -----------------------------------------------------------------------------
# App — Basis-URL für E-Mail-Links (Verifikation, Passwort-Reset)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Mail — System-E-Mails (Verifikation, Passwort-Reset)
# -----------------------------------------------------------------------------
# Provider: dev | smtp | brevo | resend | disabled
# Ohne Angabe: dev in NODE_ENV=development, sonst disabled
MAIL_PROVIDER="dev"
MAIL_FROM="noreply@alles-wurst.de"
MAIL_FROM_NAME="Alles Wurst"

# Staff-/Admin-Benachrichtigungen (neue Tickets, Nutzerantworten, …)
# Nutzerbezogene Transaktionsmails (Verify, Reset, Beta-Invite) bleiben beim Empfänger.
# Fallback-Alias: SUPPORT_NOTIFY_EMAIL / SUPPORT_NOTIFY
ADMIN_EMAIL="admin@alles-wurst.de"

# --- SMTP (MAIL_PROVIDER=smtp) ---
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""

# --- Brevo (MAIL_PROVIDER=brevo) ---
BREVO_API_KEY=""

# --- Resend (MAIL_PROVIDER=resend) ---
RESEND_API_KEY=""

# --- E-Mail-Warteschlange (Cron) ---
# Mindestens 32 Zeichen. Header: Authorization: Bearer <EMAIL_CRON_SECRET>
EMAIL_CRON_SECRET=""

# --- Mitgliedschafts-Verlängerung (Cron) ---
# Täglich: Erinnerungen (7/30 Tage), Ablauf, geplante Kontolöschungen
# POST /api/cron/membership-renewals — Fallback: LEGAL_CRON_SECRET
# Installation: scripts/install-membership-cron.sh (auf dem Server)
MEMBERSHIP_CRON_SECRET=""

# Provider-Webhook für Zustellstatus (Bounce/Complaint/Delivered)
# Mindestens 32 Zeichen. Header: Authorization: Bearer <EMAIL_WEBHOOK_SECRET>
EMAIL_WEBHOOK_SECRET=""

# Optional: separate Verschlüsselung für Provider-Zugangsdaten in der DB
# EMAIL_ENCRYPTION_SECRET=""

# -----------------------------------------------------------------------------
# Überweisung — Bankdaten für Checkout-UI
# -----------------------------------------------------------------------------
BANK_TRANSFER_RECIPIENT="Alles Wurst GmbH"
BANK_TRANSFER_IBAN="DE00 0000 0000 0000 0000 00"
# Optional:
BANK_TRANSFER_BIC=""

# -----------------------------------------------------------------------------
# Rechnungen — Rechnungssteller & fortlaufende Nummern
# -----------------------------------------------------------------------------
INVOICE_NUMBER_PREFIX="RE"
CREDIT_NOTE_NUMBER_PREFIX="GS"
INVOICE_SELLER_NAME="Alles Wurst GmbH"
INVOICE_SELLER_STREET="Musterstraße 1"
INVOICE_SELLER_POSTAL_CODE="12345"
INVOICE_SELLER_CITY="Musterstadt"
INVOICE_SELLER_COUNTRY="Deutschland"
# Optional:
INVOICE_SELLER_VAT_ID=""
INVOICE_DEFAULT_NOTE="Bitte geben Sie bei Überweisungen den Verwendungszweck aus der Bestellung an. Vielen Dank für Ihr Vertrauen."

# -----------------------------------------------------------------------------
# Stripe — Online-Zahlungen (Test/Live getrennt)
# -----------------------------------------------------------------------------
# Dokumentation: docs/STRIPE.md
# Webhook-URL: https://<domain>/api/stripe/webhook
# WICHTIG: Keys niemals per Mail, Chat oder Git teilen!

# Aktiver Modus (test|live) — überschreibt Admin-Umschaltung, wenn gesetzt
STRIPE_MODE="test"

# Testmodus
STRIPE_PUBLISHABLE_KEY_TEST=""
STRIPE_RESTRICTED_KEY_TEST=""
STRIPE_SECRET_KEY_TEST=""
STRIPE_WEBHOOK_SECRET_TEST=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_TEST=""

# Livemodus
STRIPE_PUBLISHABLE_KEY_LIVE=""
STRIPE_RESTRICTED_KEY_LIVE=""
STRIPE_SECRET_KEY_LIVE=""
STRIPE_WEBHOOK_SECRET_LIVE=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_LIVE=""

# -----------------------------------------------------------------------------
# OpenAI — Blog SEO/KI-Analyse (Magazin-Editor)
# -----------------------------------------------------------------------------
# Ohne OPENAI_API_KEY läuft die SEO-Analyse im Fallback-Modus.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
