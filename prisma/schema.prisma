  text    String  @default("🔧 Wir arbeiten für euch an Verbesserungen\n\nAktuell überarbeiten wir unsere Plattform,\nerstellen neue Inhalte und verbessern bestehende Funktionen.\n\nWir sind bald wieder für euch da.\n\nVielen Dank für eure Geduld.\n\nEuer Alles-Wurst-Team") @db.Text
  showLogo Boolean @default(true) @map("show_logo")
  logoStorageKey     String? @map("logo_storage_key")
  logoFileName       String? @map("logo_file_name")
  logoMimeType       String? @map("logo_mime_type")
  backgroundStorageKey String? @map("background_storage_key")
  backgroundFileName   String? @map("background_file_name")
  backgroundMimeType   String? @map("background_mime_type")
  countdownEnabled Boolean @default(false) @map("countdown_enabled")
  endDate DateTime? @map("end_date")
  /// "503" oder "200"
  httpStatus String @default("503") @map("http_status")
