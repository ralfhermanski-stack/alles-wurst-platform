/// Zähler für fortlaufende Zertifikatsnummern
model CertificateSequence {
  id String @id @default("default")

  sequenceYear  Int @map("sequence_year")
  currentNumber Int @default(0) @map("current_number")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("certificate_sequences")
}

/// Editierbare Urkunden-/Zertifikatsvorlage.
/// id ist der Nachweistyp: "certificate" (Zertifikat) oder "participation" (Teilnahmeurkunde).
model CertificateTemplate {
  id String @id @default("certificate")

  /// Seitenformat: "portrait" (DIN A4 hoch) oder "landscape" (DIN A4 quer)
  format String @default("landscape")

  backgroundStorageKey String? @map("background_storage_key")
  backgroundFileName   String? @map("background_file_name")

  instructorName  String @default("Ralf Hermanski") @map("instructor_name")
  instructorTitle String @default("Fleischermeister seit 1994") @map("instructor_title")

  /// Platzhalter-Konfiguration (Position, Schrift, Farbe) in Prozent der Seite
  placeholders Json @default("[]")

  /// Frei editierbare Textelemente (Rechtshinweise, Fußnoten) in Prozent der Seite
  textFields Json @default("[]") @map("text_fields")

  /// QR-Code-Konfiguration (Position, Größe in Prozent)
  qrConfig Json @default("{\"x\":82,\"y\":72,\"size\":12}") @map("qr_config")

