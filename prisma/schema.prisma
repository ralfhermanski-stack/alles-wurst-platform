  @@unique([courseId, userId])
  @@index([courseId, status])
  @@index([status])
  @@index([status, featuredOnHomepage])
  @@map("course_reviews")
}

enum PlatformReviewFocus {
  platform
  courses
  recipes
  tools
  community
  support
}

enum PlatformReviewModerationStatus {
  pending
  approved
  rejected
  archived
}

enum MemberCountDisplayMode {
  exact
  rounded
  hidden
}

enum HomepageReviewsEmptyMode {
  message
  hidden
}

enum PlatformReviewEligibilityRule {
  days_registered
  course_started
  recipe_saved
  tool_used
}

/// Bewertung der gesamten Plattform durch ein Mitglied
model PlatformReview {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rating  Int
  title   String? @db.VarChar(100)
  content String  @db.Text
  focus   PlatformReviewFocus @default(platform)

  moderationStatus PlatformReviewModerationStatus @default(pending) @map("moderation_status")
  publicConsent    Boolean @default(false) @map("public_consent")
  showMembership   Boolean @default(false) @map("show_membership")

  featuredOnHomepage Boolean @default(false) @map("featured_on_homepage")

  displayNameSnapshot     String? @map("display_name_snapshot")
  avatarUrlSnapshot       String? @map("avatar_url_snapshot")
  membershipLabelSnapshot String? @map("membership_label_snapshot")

  submittedAt     DateTime  @default(now()) @map("submitted_at")
  reviewedAt      DateTime? @map("reviewed_at")
  reviewedById    String?   @map("reviewed_by_id") @db.Uuid
  reviewedBy      User?     @relation("PlatformReviewModerator", fields: [reviewedById], references: [id], onDelete: SetNull)
  rejectionReason String?   @map("rejection_reason") @db.Text
  publishedAt     DateTime? @map("published_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId])
  @@index([moderationStatus])
  @@index([moderationStatus, featuredOnHomepage])
  @@map("platform_reviews")
}

/// Einstellungen für den Startseiten-Bereich „Stimmen aus der Community“
model HomepageCommunityReviewsSettings {
  id String @id @default("default")

  memberCountDisplay   MemberCountDisplayMode @default(exact) @map("member_count_display")
  showAverageRating    Boolean @default(true) @map("show_average_rating")
  minReviewsForAverage Int     @default(5) @map("min_reviews_for_average")
  emptyStateMode       HomepageReviewsEmptyMode @default(message) @map("empty_state_mode")
  eligibilityRule      PlatformReviewEligibilityRule @default(days_registered) @map("eligibility_rule")
  minRegistrationDays  Int     @default(7) @map("min_registration_days")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("homepage_community_reviews_settings")
}

/// Forum (Kursforum, globales Minikurs-Forum oder allgemein)
model Forum {
  id String @id @default(uuid()) @db.Uuid

  title       String
  slug        String @unique
  description String? @db.Text

  forumType    ForumType    @map("forum_type")
  forumPurpose ForumPurpose @default(custom) @map("forum_purpose")

  /// Leseregel (ergänzt forumType — Admin kann für general überschreiben)
  readAccess ForumReadAccess @default(registered) @map("read_access")

  /// Schreiben erlaubt (bei false nur Lesen)
  writeEnabled Boolean @default(true) @map("write_enabled")

  /// Erforderliche Mitgliedschaftsrolle (forumType = membership)
  requiredMembershipRole MembershipRole? @map("required_membership_role")

  courseId String? @map("course_id") @db.Uuid
  course   Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)

  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  threads ForumThread[]
  communityChallenges CommunityChallenge[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([courseId, forumPurpose])
  @@index([forumType])
  @@index([courseId])
  @@index([isActive, sortOrder])
  @@map("forums")
}

/// Forum-Thread (Thema)
model ForumThread {
  id String @id @default(uuid()) @db.Uuid

  forumId String @map("forum_id") @db.Uuid
  forum   Forum  @relation(fields: [forumId], references: [id], onDelete: Cascade)

  authorUserId String @map("author_user_id") @db.Uuid
  author       User   @relation(fields: [authorUserId], references: [id], onDelete: Cascade)

  title String
  slug  String
  body  String @db.Text

  isLocked Boolean @default(false) @map("is_locked")

  displayNameSnapshot String? @map("display_name_snapshot")
  avatarUrlSnapshot   String? @map("avatar_url_snapshot")
  authorRoleBadge     String? @map("author_role_badge")

  posts ForumPost[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([forumId, slug])
  @@index([forumId, createdAt])
  @@map("forum_threads")
}

/// Forum-Beitrag (Antwort auf Thread)
model ForumPost {
  id String @id @default(uuid()) @db.Uuid

  threadId String      @map("thread_id") @db.Uuid
  thread   ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  authorUserId String @map("author_user_id") @db.Uuid
  author       User   @relation(fields: [authorUserId], references: [id], onDelete: Cascade)

  body String @db.Text

  displayNameSnapshot String? @map("display_name_snapshot")
  avatarUrlSnapshot   String? @map("avatar_url_snapshot")
  authorRoleBadge     String? @map("author_role_badge")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([threadId, createdAt])
  @@map("forum_posts")
}

/// Systemweite Einstellungen (z. B. globale Minikurs-Foren)
model SystemSetting {
  key   String @id
  value String @db.Text

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

/// Wartungsmodus — Singleton (id = "default")
model MaintenanceSettings {
