// =============================================================================
// prisma/schema.prisma — Datenbankschema für Alles-Wurst 2.0
// =============================================================================
// Stand: Schritt 17 (Zahlungsgrundlage)
//
// Enthält:
//   - ConnectionTest  — technischer Verbindungstest (Schritt 1)
//   - Recipe          — Wurstrezepte für den Rezeptgenerator (Schritt 2)
//   - RecipeCategory  — verwaltete Wurstkategorien (Schritt 9)
//   - RecipeGeneratorSettings — globale PDF-/Tool-Einstellungen (Schritt 9)
//   - User / UserProfile — Nutzerstamm mit Adresse (Schritt 12)
//   - Membership — Mitgliedschaft, Zahlung, Buchhaltungsvermerke (Schritt 12)
//
// Fachmodell: docs/REZEPTGENERATOR_DATENMODELL.md (Version 1.1)
// Einrichtung:  docs/DATENBANK_SETUP.md
// =============================================================================

// Prisma Client Generator — erzeugt typsicheren TypeScript-Client
generator client {
  provider = "prisma-client-js"
}

// PostgreSQL als Datenbank — Verbindung über DATABASE_URL in .env
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// ConnectionTest — Minimaler technischer Verbindungstest
// -----------------------------------------------------------------------------
// Zweck:
//   Prüft, ob die Anwendung die Datenbank erreichen und schreiben kann.
//   Keine Fachdaten — wird in scripts/test-db-connection.cjs verwendet.
//
// Verwendung:
//   npm run db:test
// -----------------------------------------------------------------------------
model ConnectionTest {
  /// Eindeutige ID (UUID, von Prisma automatisch vergeben)
  id String @id @default(uuid()) @db.Uuid

  /// Kurze Statusmeldung — Standard: "ok"
  message String @default("ok")

  /// Zeitpunkt des Verbindungstests (automatisch beim INSERT)
  checkedAt DateTime @default(now()) @map("checked_at")

  /// Tabellenname in PostgreSQL (snake_case-Konvention)
  @@map("connection_test")
}

// =============================================================================
// Enums — Rezeptgenerator (Stammdaten)
// =============================================================================

/// Lebenszyklus eines Rezepts im Rezeptgenerator
enum RecipeStatus {
  /// In Bearbeitung, noch nicht final gespeichert
  draft
  /// Vom Nutzer gespeichert
  saved
  /// Veröffentlicht (z. B. in Rezeptdatenbank — ab Meister-Stufe)
  published
}

/// Sichtbarkeit / Veröffentlichungsstufe des Rezepts
enum RecipeVisibility {
  /// Nur für den Besitzer sichtbar
  private
  /// Öffentlich im Profil sichtbar
  public
  /// In der gemeinsamen Rezeptdatenbank (Meister)
  database
}

/// Moderationsstatus für Admin-Freigabe-Workflow
enum RecipeModerationStatus {
  /// Keine Moderation angefordert
  none
  /// Wartet auf Admin-Prüfung
  pending
  /// Vom Admin freigegeben
  approved
  /// Vom Admin abgelehnt
  rejected
  /// Vom Admin gesperrt
  blocked
}

/// Rezeptart — Wurstrezept vs. Marinade (getrennte Generatoren)
enum RecipeKind {
  wurst
  marinade
}

/// PDF-Status für gespeicherte Rezept-PDFs
enum RecipePdfStatus {
  none
  current
  outdated
}

/// Herkunft eines Rezepts — steuert Teilen-Freigabe
enum RecipeSource {
  USER
  ADMIN
  PREMIUM_DATABASE
}

// -----------------------------------------------------------------------------
// Recipe — Wurstrezept (Rezeptgenerator)
// -----------------------------------------------------------------------------
// Zweck:
//   Speichert Stammdaten und Berechnungsgrundlage eines Rezepts.
//   Detaildaten (Fleisch, Schüttung, Gewürze, Hülle, Produktion, Räuchern)
//   liegen im JSON-Feld `payload` — siehe REZEPTGENERATOR_DATENMODELL.md §2.4.
//
// Bewusst NICHT enthalten:
//   - Analyse-Felder (analysis_snapshot, analysis_score) — nur in
//     recipe_analysis_snapshots (Phase 4, separates Modul)
//   - FK zu users — userId bleibt UUID-String ohne FK, bis bestehende
//     localStorage-IDs bei Registrierung verknüpft sind (Schritt 12+)
//
// Payload-Inhalt (JSON, nicht relational):
//   - calculation, meats (+ S1–S10/R1–R5), binders, schuettung
//   - ingredients (+ referenceBasis), casing, production, smoking
// -----------------------------------------------------------------------------
model Recipe {
  /// Eindeutige Rezept-ID (UUID)
  id String @id @default(uuid()) @db.Uuid

  /// Besitzer (Ersteller) — UUID ohne FK, bis User-Tabelle angelegt ist
  userId String @map("user_id") @db.Uuid

  /// Rezeptname (Pflichtfeld in der Anwendung)
  name String

  /// Wurstkategorie (z. B. Rohwurst, Brühwurst) — optional, Freitext bis Katalog existiert
  category String?

  /// Kurzbeschreibung / Notizen
  description String? @db.Text

  /// Zustand: draft | saved | published
  status RecipeStatus @default(draft)

  /// Sichtbarkeit: private | public | database
  visibility RecipeVisibility @default(private)

  /// Ziel-Gesamtgewicht der Charge in kg (dupliziert aus payload.calculation für Abfragen)
  totalWeightKg Decimal? @map("total_weight_kg") @db.Decimal(10, 3)

  /// Vollständige Rezeptdaten als JSON (Fleisch, Gewürze, Herstellung usw.)
  payload Json @default("{}")

  /// Versionsnummer — wird bei jeder inhaltlichen Speicherung erhöht (ab erstem Save)
  version Int @default(1)

  /// Zeitpunkt der Veröffentlichung in der Rezeptdatenbank (null = nicht veröffentlicht)
  publishedAt DateTime? @map("published_at")

  /// Erstellungszeitpunkt (UTC)
  createdAt DateTime @default(now()) @map("created_at")

  /// Letzte Änderung (automatisch von Prisma aktualisiert)
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Soft-Delete — null = aktiv, gesetzt = gelöscht (logisch)
  deletedAt DateTime? @map("deleted_at")

  /// Moderationsstatus (Admin-Freigabe-Workflow)
  moderationStatus RecipeModerationStatus @default(none) @map("moderation_status")

  /// Interner Admin-Kommentar (z. B. Ablehnungsgrund)
  adminComment String? @map("admin_comment") @db.Text

  /// Zeitpunkt der letzten Moderationsentscheidung
  moderationReviewedAt DateTime? @map("moderation_reviewed_at")

  /// In offizieller Rezeptdatenbank übernommen
  isOfficialDatabase Boolean @default(false) @map("is_official_database")

  /// Freigabe-Flag: „Rezept des Monats“ (für registrierte Mitglieder).
  isRecipeOfMonth Boolean @default(false) @map("is_recipe_of_month")

  /// Flag: Rezept ist ein „Kursrezept“ und soll in der Rezeptdatenbank
  /// erst nach Kursbuchung freigegeben werden.
  isCourseLinked Boolean @default(false) @map("is_course_linked")

  /// Flag: „Besondere Meisterclub-Rezepte“, die nur Meisterclub-Mitglieder sehen sollen.
  isMeisterclubSpecial Boolean @default(false) @map("is_meisterclub_special")

  /// Herkunft — nur USER-Rezepte dürfen geteilt werden
  source RecipeSource @default(USER)

  /// Zeitpunkt der Sperrung durch Admin
  blockedAt DateTime? @map("blocked_at")

  /// Rezeptbild — Speicherschlüssel und Originaldateiname (kein Einbrennen)
  imageStorageKey String? @map("image_storage_key")
  imageFileName   String? @map("image_file_name")

  /// Rezeptart: wurst (Standard) | marinade
  recipeKind RecipeKind @default(wurst) @map("recipe_kind")

  /// Gespeichertes PDF (serverseitig, geschützter Download)
  pdfStorageKey  String?         @map("pdf_storage_key")
  pdfGeneratedAt DateTime?       @map("pdf_generated_at")
  pdfVersion     Int?            @map("pdf_version")
  pdfStatus      RecipePdfStatus @default(none) @map("pdf_status")

  publicShares PublicShare[]
  productRecommendationLinks ProductRecommendationRecipeLink[]

  /// Abfragen nach Besitzer (z. B. „meine Rezepte“)
  @@index([userId])
  /// Filter in Rezeptdatenbank / Sichtbarkeitsprüfungen
  @@index([visibility])
  /// Filter nach Wurstkategorie
  @@index([category])
  /// Admin-Moderationsqueue
  @@index([moderationStatus])
  @@index([recipeKind])
  @@index([source])
  @@map("recipes")
}

// -----------------------------------------------------------------------------
// RecipeCategory — Verwaltete Wurstkategorien (Admin)
// -----------------------------------------------------------------------------
model RecipeCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  slug        String   @unique
  description String?  @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("recipe_categories")
}

// -----------------------------------------------------------------------------
// RecipeGeneratorSettings — Globale Einstellungen (Singleton, id = "default")
// -----------------------------------------------------------------------------
model RecipeGeneratorSettings {
  id                 String   @id @default("default")
  pdfHeaderText      String   @default("Alles-Wurst Rezeptgenerator") @map("pdf_header_text")
  pdfFooterText      String   @default("Erstellt mit dem Alles-Wurst Rezeptgenerator") @map("pdf_footer_text")
  pdfLogoPlaceholder String   @default("Logo") @map("pdf_logo_placeholder")
  pdfLegalNotice     String   @default("") @map("pdf_legal_notice") @db.Text
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("recipe_generator_settings")
}

// =============================================================================
// Enums — User, Mitgliedschaft & Zahlung (Schritt 12)
// =============================================================================

/// Mitgliedschaftsstufe / Systemrolle (persistiert in `memberships.role`)
enum MembershipRole {
  guest
  registered
  wurstclub
  meisterclub
  accounting
  /// @deprecated Nur noch für Legacy-Daten — Adminrechte über User.systemRole
  admin
}

/// Systemrolle des Nutzers (getrennt von Mitgliedschaftslevel)
enum UserSystemRole {
  USER
  ADMIN
  SUPPORT
  INSTRUCTOR
  /// Vollzugriff auf Rechteverwaltung und kritische Systemeinstellungen
  SUPERADMIN
}

/// Kontostatus (Login und Plattformzugriff)
enum UserAccountStatus {
  active
  suspended
  deactivated
}

/// Lebenszyklus einer Mitgliedschaft
enum MembershipStatus {
  /// Keine aktive Mitgliedschaft (Basis nach Registrierung)
  none
  /// Aktiv und gültig
  active
  /// Vorübergehend pausiert (z. B. durch Buchhaltung)
  paused
  /// Vom Nutzer oder Support beendet
  cancelled
  /// Abgelaufen (Enddatum überschritten)
  expired
  /// Gesperrt — kein Club-/Rezeptzugriff
  blocked
}

/// Zahlungsstatus der Mitgliedschaft
enum PaymentStatus {
  /// Noch keine Zahlung erforderlich / nicht relevant
  none
  /// Zahlung ausstehend
  pending
  /// Bezahlt
  paid
  /// Zahlung fehlgeschlagen
  failed
  /// Überfällig
  overdue
  /// Erstattet
  refunded
}

// -----------------------------------------------------------------------------
// User — Plattform-Nutzer (Registrierung & Login vorbereitet)
// -----------------------------------------------------------------------------
// Zweck:
//   Zentraler Nutzerstamm für Registrierung, Login und Mitgliedschaft.
//   Passwort und E-Mail-Verifikation werden erst in späteren Schritten genutzt.
//
// Bewusst noch NICHT angebunden:
//   - Kein Login, keine Session, kein Ersetzen von localStorage-userId
// -----------------------------------------------------------------------------
model User {
  id String @id @default(uuid()) @db.Uuid

  /// Eindeutige E-Mail (Login-Kennung — später)
  email String @unique

  /// Passwort-Hash (bcrypt/argon2 — null bis Registrierung abgeschlossen)
  passwordHash String? @map("password_hash")

  /// Zeitpunkt der E-Mail-Bestätigung (null = unbestätigt)
  emailVerifiedAt DateTime? @map("email_verified_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Soft-Delete — null = aktiv
  deletedAt DateTime? @map("deleted_at")

  /// Systemrolle (Adminrechte) — unabhängig von Mitgliedschaft
  systemRole UserSystemRole @default(USER) @map("system_role")

  /// Kontostatus (aktiv / gesperrt / deaktiviert)
  accountStatus UserAccountStatus @default(active) @map("account_status")

  /// Letzter erfolgreicher Login (optional)
  lastLoginAt DateTime? @map("last_login_at")

  /// Wartungsmodus: normale Website trotz Wartung sehen (ohne Admin-Rolle)
  maintenanceBypass Boolean @default(false) @map("maintenance_bypass")

  stripeCustomerIdTest String? @map("stripe_customer_id_test")
  stripeCustomerIdLive String? @map("stripe_customer_id_live")

  profile    UserProfile?
  membership Membership?
  auditLogs  MembershipAuditLog[] @relation("AuditTargetUser")
  accountingPositions AccountingPosition[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  checkoutIntents         CheckoutIntent[]
  courseAccess            CourseAccess[]
  invoices                Invoice[]
  creditNotes             CreditNote[]
  courseLessonProgress    CourseLessonProgress[]
  userCourseAccess        UserCourseAccess[]
  courseCertificates      UserCourseCertificate[]
  courseReviews           CourseReview[]
  platformReviews         PlatformReview[]
  platformReviewsModerated PlatformReview[] @relation("PlatformReviewModerator")
  forumThreads            ForumThread[]
  forumPosts              ForumPost[]
  supportTicketsCreated   SupportTicket[]         @relation("SupportTicketCreator")
  supportTicketsAssigned  SupportTicket[]         @relation("SupportTicketAssignee")
  supportTicketMessages   SupportTicketMessage[]
  supportTicketInternalNotes SupportTicketInternalNote[]
  supportTicketAttachments SupportTicketAttachment[] @relation("SupportAttachmentUploader")
  supportTicketEvents     SupportTicketEvent[]    @relation("SupportTicketEventActor")
  blogPostsAuthored       BlogPost[]              @relation("BlogPostAuthor")
  challengeSubmissions    ChallengeSubmission[]
  challengeVotes          ChallengeVote[]
  challengeUserStates     ChallengeUserState[]
  challengeNotificationLogs ChallengeNotificationLog[]
  withdrawalRequestsAssigned WithdrawalRequest[] @relation("WithdrawalAssignee")
  withdrawalRequests         WithdrawalRequest[] @relation("WithdrawalUser")
  legalDocumentVersionsPublished LegalDocumentVersion[] @relation("LegalVersionPublisher")
  legalDocumentVersionsImported  LegalDocumentVersion[] @relation("LegalVersionImporter")
  legalAcceptances               UserLegalAcceptance[]
  accountMessages            UserAccountMessage[]
  privacyRequests            PrivacyRequest[]
  privacyRequestsAssigned    PrivacyRequest[] @relation("PrivacyAssignee")
  dataExportRequests         DataExportRequest[]
  accountDeletionPlans       AccountDeletionPlan[]
  accountDataRetentions      AccountDataRetention[]
  membershipRenewalReminderLogs MembershipRenewalReminderLog[]
  emailMessagesRequested     EmailMessage[]          @relation("EmailRequestedBy")
  emailTemplateVersionsCreated EmailTemplateVersion[] @relation("EmailTemplateCreator")
  emailTemplateVersionsPublished EmailTemplateVersion[] @relation("EmailTemplatePublisher")
  emailPreferences           EmailPreference[]
  publicShares               PublicShare[]
  userGroupMembers           UserGroupMember[]
  userPermissions            UserPermission[]
  permissionAuditLogsTarget  PermissionAuditLog[] @relation("PermissionAuditTarget")
  permissionAuditLogsActor   PermissionAuditLog[] @relation("PermissionAuditActor")
  userGroupMembersAssigned   UserGroupMember[]    @relation("UserGroupAssignedBy")
  userPermissionsAssigned    UserPermission[]     @relation("UserPermissionAssignedBy")
  productRecommendationClickEvents ProductRecommendationClickEvent[]
  securityEvents                 SecurityEvent[]
  securityAuditLogsAsActor       SecurityAuditLog[] @relation("SecurityAuditActor")
  securityAuditLogsAsTarget      SecurityAuditLog[] @relation("SecurityAuditTarget")
  userSessions                   UserSession[]
  userTotp                       UserTotp?
  totpBackupCodes                TotpBackupCode[]
  suspiciousUserFlags            SuspiciousUserFlag[]
  blockedIpsCreated              BlockedIp[] @relation("BlockedIpCreatedBy")
  betaInvitesSent                BetaInvite[] @relation("BetaInvitesSent")
  betaInvitesAccepted            BetaInvite[] @relation("BetaInvitesAccepted")
  betaTesterTasks                BetaTesterTask[] @relation("BetaTesterTasks")
  betaTesterTasksAssigned        BetaTesterTask[] @relation("BetaTasksAssigned")

  @@index([deletedAt])
  @@map("users")
}

// -----------------------------------------------------------------------------
// EmailVerificationToken — Einmal-Token zur E-Mail-Bestätigung (nur Hash in DB)
// -----------------------------------------------------------------------------
model EmailVerificationToken {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// HMAC-SHA256-Hash des Klartext-Tokens (Klartext nur in E-Mail/Link)
  tokenHash String @map("token_hash")

  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

// -----------------------------------------------------------------------------
// PasswordResetToken — Einmal-Token zum Passwort zurücksetzen (nur Hash in DB)
// -----------------------------------------------------------------------------
model PasswordResetToken {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// HMAC-SHA256-Hash des Klartext-Tokens
  tokenHash String @map("token_hash")

  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// -----------------------------------------------------------------------------
// UserProfile — Persönliche Daten und vollständige Adresse
// -----------------------------------------------------------------------------
model UserProfile {
  id String @id @default(uuid()) @db.Uuid

  userId String @unique @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Anrede (z. B. Herr, Frau, Divers)
  salutation String?

  /// Öffentlich sichtbarer Anzeigename (Forum/Bewertungen).
  /// Muss eindeutig sein (oder zumindest validiert).
  publicName String? @unique @map("public_name")

  /// Öffentliche Avatar-URL (z. B. /api/users/{id}/avatar oder externe URL).
  avatarUrl String? @map("avatar_url")

  /// Interner Speicherpfad für hochgeladenes Profilbild.
  avatarStorageKey String? @map("avatar_storage_key")
  avatarFileName   String? @map("avatar_file_name")

  /// Kurze öffentliche Profilbeschreibung (Plain-Text oder Rich-Text-HTML).
  bio String? @db.Text

  /// Bio unter eigenen Forenbeiträgen als Signatur anzeigen.
  useBioAsForumSignature Boolean @default(false) @map("use_bio_as_forum_signature")

  firstName String @map("first_name")
  lastName  String @map("last_name")

  /// Firmenname (optional, z. B. Metzgerei)
  company String?

  street      String
  houseNumber String  @map("house_number")
  addressLine2 String? @map("address_line2")

  postalCode String @map("postal_code")
  city       String

  /// Bundesland / Region (optional)
  stateRegion String? @map("state_region")

  /// ISO-Ländercode (Standard: DE)
  country String @default("DE")

  phone String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_profiles")
}

// -----------------------------------------------------------------------------
// Membership — Mitgliedschaft, Zahlung & manuelle Korrekturen (Buchhaltung)
// -----------------------------------------------------------------------------
// Zweck:
//   Eine Mitgliedschaft pro Nutzer (1:1). Buchhaltung kann Status, Zahlung
//   und Zugriffssperre manuell korrigieren, wenn Webhooks nicht greifen.
//
// Bewusst noch NICHT angebunden:
//   - Keine PayPal/Stripe/Überweisung, keine Buchhaltungs-UI
// -----------------------------------------------------------------------------
model Membership {
  id String @id @default(uuid()) @db.Uuid

  userId String @unique @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role   MembershipRole   @default(registered)
  status MembershipStatus @default(none)
  paymentStatus PaymentStatus @default(none) @map("payment_status")

  /// Öffentliche Zahlungsnotiz (z. B. für Support-Kommunikation)
  paymentNote String? @map("payment_note") @db.Text

  /// Interner Buchhaltungsvermerk (nicht für Nutzer sichtbar)
  accountingNote String? @map("accounting_note") @db.Text

  /// Manuelle Zugriffssperre für Rezept-/Club-Funktionen
  accessBlocked Boolean @default(false) @map("access_blocked")

  /// Begründung für Sperre oder manuelle Korrektur
  blockReason String? @map("block_reason") @db.Text

  /// Beginn der Mitgliedschaft
  startedAt DateTime? @map("started_at")

  /// Geplantes oder tatsächliches Ende
  endsAt DateTime? @map("ends_at")

  /// Manuelle Verlängerung (Buchhaltung) — überschreibt endsAt logisch
  extendedUntil DateTime? @map("extended_until")

  /// Abrechnungsperiode des aktiven Abos (monatlich/jährlich)
  billingPeriod BillingPeriod? @map("billing_period")

  /// Automatische Verlängerung aktiv (Stripe-Abo)
  autoRenewEnabled Boolean @default(true) @map("auto_renew_enabled")

  /// Keine Verlängerung — läuft zum Periodenende aus
  cancelAtPeriodEnd Boolean @default(false) @map("cancel_at_period_end")

  /// Grund der Kündigung zum Periodenende
  cancelReason MembershipCancelReason? @map("cancel_reason")

  /// Zeitpunkt der Kündigungsanfrage
  cancelRequestedAt DateTime? @map("cancel_requested_at")

  /// Admin: Verlängerungshinweise unterdrücken
  renewalRemindersSuppressed Boolean @default(false) @map("renewal_reminders_suppressed")

  /// Für welches Periodenende zuletzt eine Erinnerung gesendet wurde (Idempotenz)
  lastRenewalReminderForPeriodEnd DateTime? @map("last_renewal_reminder_for_period_end")

  renewalReminderLogs MembershipRenewalReminderLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([role])
  @@index([paymentStatus])
  @@index([accessBlocked])
  @@index([cancelAtPeriodEnd])
  @@index([extendedUntil])
  @@index([endsAt])
  @@map("memberships")
}

/// Grund für Kündigung zum Periodenende
enum MembershipCancelReason {
  user_request
  account_deletion
  admin
  stripe_sync
  payment_failed
}

/// Status eines Verlängerungshinweises
enum MembershipRenewalReminderStatus {
  sent
  skipped
  failed
  suppressed
}

/// Protokoll gesendeter Verlängerungshinweise (Admin-Nachvollziehbarkeit)
model MembershipRenewalReminderLog {
  id String @id @default(cuid())

  membershipId String     @map("membership_id") @db.Uuid
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  billingPeriod BillingPeriod @map("billing_period")
  periodEndAt   DateTime      @map("period_end_at")
  leadDays      Int           @map("lead_days")

  status     MembershipRenewalReminderStatus
  skipReason String? @map("skip_reason") @db.Text
  errorMessage String? @map("error_message") @db.Text

  /// cron | admin_manual
  triggeredBy String @default("cron") @map("triggered_by")
  actorUserId String? @map("actor_user_id") @db.Uuid

  emailMessageId String? @map("email_message_id")

  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@unique([membershipId, periodEndAt, leadDays])
  @@index([userId])
  @@index([status])
  @@index([periodEndAt])
  @@index([createdAt])
  @@map("membership_renewal_reminder_logs")
}

/// Audit-Aktionen der Buchhaltung (Mitgliedschaft & Zahlung)
enum MembershipAuditAction {
  membership_pause
  membership_reactivate
  membership_extend
  membership_end
  membership_block
  membership_unlock
  payment_status_change
  role_change
  payment_note
  accounting_note
  manual_update
  position_create
  position_update
  position_status_change
  checkout_create
  payment_intent_create
  payment_fulfillment
  invoice_create
  invoice_cancel
  credit_note_create
  user_suspend
  user_activate
  user_deactivate
  system_role_change
  course_access_grant
  course_access_revoke
}

// -----------------------------------------------------------------------------
// MembershipAuditLog — Änderungsverlauf für Buchhaltungs-Korrekturen
// -----------------------------------------------------------------------------
model MembershipAuditLog {
  id String @id @default(uuid()) @db.Uuid

  /// Betroffener Nutzer
  targetUserId String @map("target_user_id") @db.Uuid
  targetUser   User   @relation("AuditTargetUser", fields: [targetUserId], references: [id], onDelete: Cascade)

  /// Ausführende Person (Buchhaltung oder Admin)
  actorUserId String @map("actor_user_id") @db.Uuid
  actorRole   MembershipRole @map("actor_role")

  action MembershipAuditAction

  /// Kurzbeschreibung auf Deutsch
  summary String

  /// Vorherige Werte (JSON-Snapshot relevanter Felder)
  previousValues Json? @map("previous_values")

  /// Neue Werte (JSON-Snapshot relevanter Felder)
  newValues Json? @map("new_values")

  /// Optionaler Vermerk zur Aktion
  note String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  @@index([targetUserId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("membership_audit_logs")
}

/// Produkttyp einer Buchhaltungsposition
enum AccountingProductType {
  membership
  course
  workshop
  manual
}

/// Zahlungsstatus einer Buchhaltungsposition (Kurs, Workshop, manuell)
enum AccountingPositionPaymentStatus {
  pending
  paid
  overdue
  cancelled
  refunded
}

// -----------------------------------------------------------------------------
// AccountingPosition — Nutzerbezogene Kurs-/Produktkosten & manuelle Posten
// -----------------------------------------------------------------------------
// Zweck:
//   Buchhaltungspositionen pro Nutzer — Kurskäufe, Workshops, Mitgliedschaften
//   und manuelle Korrekturen. Vorbereitet für LearnPress/PMP, noch ohne Anbindung.
//
// Bewusst noch NICHT enthalten:
//   - Rechnungserstellung, Stripe/PayPal, LearnPress-Sync
// -----------------------------------------------------------------------------
model AccountingPosition {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  productType AccountingProductType @map("product_type")
  productName String @map("product_name")

  grossAmount Decimal @map("gross_amount") @db.Decimal(12, 2)
  netAmount   Decimal @map("net_amount") @db.Decimal(12, 2)
  taxRate     Decimal @map("tax_rate") @db.Decimal(5, 2)
  taxAmount   Decimal @map("tax_amount") @db.Decimal(12, 2)
  currency    String  @default("EUR")

  paymentStatus AccountingPositionPaymentStatus @default(pending) @map("payment_status")

  dueDate DateTime? @map("due_date")
  paidAt  DateTime? @map("paid_at")

  note String? @db.Text

  /// Verknüpfung zum Produktkatalog (optional)
  productPriceId String? @map("product_price_id") @db.Uuid
  productPrice   ProductPrice? @relation(fields: [productPriceId], references: [id], onDelete: SetNull)

  /// Gewählter Zahlungsanbieter (bei Checkout-Vorbereitung)
  paymentProvider PaymentProvider? @map("payment_provider")

  checkoutIntent CheckoutIntent?
  paymentIntents PaymentIntent[]
  invoice        Invoice?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([paymentStatus])
  @@index([productType])
  @@index([dueDate])
  @@index([productPriceId])
  @@index([paymentProvider])
  @@map("accounting_positions")
}

// =============================================================================
// Enums & Modelle — Zahlungsgrundlage (Schritt 17)
// =============================================================================

/// Produktart im Katalog (Mitgliedschaft, Kurs, Workshop)
enum ProductKind {
  membership_wurstclub
  membership_meisterclub
  course
  workshop
}

/// Abrechnungszeitraum eines Preises
enum BillingPeriod {
  one_time
  monthly
  yearly
}

/// Zahlungsanbieter (vorbereitet für Stripe, PayPal, Überweisung)
enum PaymentProvider {
  stripe
  paypal
  bank_transfer
  manual
}

/// Status eines Checkout-Intents (Warenkorb / Kaufabsicht)
enum CheckoutIntentStatus {
  created
  awaiting_payment
  processing
  succeeded
  failed
  cancelled
  expired
}

/// Status eines Payment-Intents (konkreter Zahlungsversuch)
enum PaymentIntentStatus {
  created
  awaiting_payment
  processing
  succeeded
  failed
  cancelled
  expired
}

/// Status eines Kurs-/Workshop-Zugriffs
enum CourseAccessStatus {
  pending
  active
  revoked
  expired
}

/// Herkunft eines Kurszugriffs
enum CourseAccessSource {
  payment
  manual
  accounting
  membership_bonus
}

// -----------------------------------------------------------------------------
// Product — Katalogprodukt (Wurstclub, Meisterclub, Kurse, Workshops)
// -----------------------------------------------------------------------------
model Product {
  id String @id @default(uuid()) @db.Uuid

  kind ProductKind
  slug String @unique
  name String
  description String? @db.Text

  active    Boolean @default(true)
  sortOrder Int     @default(0) @map("sort_order")

  /// Rechtliche Vertragsart (fachlich vor Livegang prüfen)
  legalProductType LegalProductType? @map("legal_product_type")
  legalConfig      Json              @default("{}") @map("legal_config")

  /// Externe Referenz (z. B. LearnPress-Kurs-ID — später)
  externalRef String? @map("external_ref")

  prices       ProductPrice[]
  courseAccess CourseAccess[]
  course       Course?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([kind])
  @@index([active])
  @@map("products")
}

// -----------------------------------------------------------------------------
// ProductPrice — Preis zu einem Katalogprodukt
// -----------------------------------------------------------------------------
model ProductPrice {
  id String @id @default(uuid()) @db.Uuid

  productId String  @map("product_id") @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  grossAmount Decimal @map("gross_amount") @db.Decimal(12, 2)
  netAmount   Decimal @map("net_amount") @db.Decimal(12, 2)
  taxRate     Decimal @map("tax_rate") @db.Decimal(5, 2)
  taxAmount   Decimal @map("tax_amount") @db.Decimal(12, 2)
  currency    String  @default("EUR")

  billingPeriod BillingPeriod @default(one_time) @map("billing_period")

  active    Boolean   @default(true)
  validFrom DateTime? @map("valid_from")
  validUntil DateTime? @map("valid_until")

  checkoutIntents     CheckoutIntent[]
  accountingPositions AccountingPosition[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([productId])
  @@index([active])
  @@map("product_prices")
}

// -----------------------------------------------------------------------------
// CheckoutIntent — Kaufabsicht (noch ohne echten Checkout)
// -----------------------------------------------------------------------------
model CheckoutIntent {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  productPriceId String       @map("product_price_id") @db.Uuid
  productPrice   ProductPrice @relation(fields: [productPriceId], references: [id], onDelete: Restrict)

  paymentProvider PaymentProvider @map("payment_provider")
  status          CheckoutIntentStatus @default(created)

  grossAmount Decimal @map("gross_amount") @db.Decimal(12, 2)
  netAmount   Decimal @map("net_amount") @db.Decimal(12, 2)
  taxRate     Decimal @map("tax_rate") @db.Decimal(5, 2)
  taxAmount   Decimal @map("tax_amount") @db.Decimal(12, 2)
  currency    String  @default("EUR")

  accountingPositionId String?             @unique @map("accounting_position_id") @db.Uuid
  accountingPosition   AccountingPosition? @relation(fields: [accountingPositionId], references: [id], onDelete: SetNull)

  paymentIntents PaymentIntent[]
  courseAccess   CourseAccess[]
  legalConsents  CheckoutLegalConsent[]
  purchaseLegalRecord PurchaseLegalRecord?

  /// Provider-spezifische Metadaten (Stripe Session-ID, PayPal Order-ID, …)
  providerMetadata Json? @map("provider_metadata")

  expiresAt   DateTime? @map("expires_at")
  completedAt DateTime? @map("completed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([paymentProvider])
  @@index([expiresAt])
  @@map("checkout_intents")
}

// -----------------------------------------------------------------------------
// PaymentIntent — Zahlungsversuch zu einem Checkout
// -----------------------------------------------------------------------------
model PaymentIntent {
  id String @id @default(uuid()) @db.Uuid

  checkoutIntentId String         @map("checkout_intent_id") @db.Uuid
  checkoutIntent   CheckoutIntent @relation(fields: [checkoutIntentId], references: [id], onDelete: Cascade)

  paymentProvider PaymentProvider @map("payment_provider")
  status          PaymentIntentStatus @default(created)

  /// Externe Referenz (z. B. Stripe pi_…, PayPal capture_id)
  providerReference String? @map("provider_reference")

  grossAmount Decimal @map("gross_amount") @db.Decimal(12, 2)
  currency    String  @default("EUR")

  accountingPositionId String?             @map("accounting_position_id") @db.Uuid
  accountingPosition   AccountingPosition? @relation(fields: [accountingPositionId], references: [id], onDelete: SetNull)

  providerMetadata Json? @map("provider_metadata")

  stripeCustomerId        String? @map("stripe_customer_id")
  stripeCheckoutSessionId String? @map("stripe_checkout_session_id")
  stripePaymentIntentId   String? @map("stripe_payment_intent_id")
  stripeChargeId          String? @map("stripe_charge_id")
  stripeSubscriptionId    String? @map("stripe_subscription_id")
  stripeInvoiceId         String? @map("stripe_invoice_id")
  customerName            String? @map("customer_name")
  customerEmail           String? @map("customer_email")
  billingAddressJson      Json?   @map("billing_address_json")
  paymentMethodType       String? @map("payment_method_type")
  webhookEventId          String? @map("webhook_event_id")
  processedAt             DateTime? @map("processed_at")
  errorMessage            String? @map("error_message") @db.Text

  paidAt   DateTime? @map("paid_at")
  failedAt DateTime? @map("failed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([checkoutIntentId])
  @@index([status])
  @@index([paymentProvider])
  @@index([providerReference])
  @@index([accountingPositionId])
  @@index([stripeCheckoutSessionId])
  @@index([stripePaymentIntentId])
  @@index([webhookEventId])
  @@map("payment_intents")
}

// =============================================================================
// Stripe-Integration
// =============================================================================

enum StripeActiveMode {
  test
  live
}

enum StripeWebhookProcessedStatus {
  pending
  processed
  ignored
  failed
}

model StripeSettings {
  id String @id @default("default")

  activeMode StripeActiveMode @default(test) @map("active_mode")

  lastWebhookAt     DateTime? @map("last_webhook_at")
  lastWebhookEventId String?  @map("last_webhook_event_id")
  lastStripeError   String?  @map("last_stripe_error") @db.Text

  apiTestOk         Boolean? @map("api_test_ok")
  apiTestCheckedAt  DateTime? @map("api_test_checked_at")
  apiLiveOk         Boolean? @map("api_live_ok")
  apiLiveCheckedAt  DateTime? @map("api_live_checked_at")

  keyStorageNoteTest String? @map("key_storage_note_test") @db.Text
  keyStorageNoteLive String? @map("key_storage_note_live") @db.Text
  keyRotatedAtTest   DateTime? @map("key_rotated_at_test")
  keyRotatedAtLive   DateTime? @map("key_rotated_at_live")

  encryptedKeysTest String? @map("encrypted_keys_test") @db.Text
  encryptedKeysLive String? @map("encrypted_keys_live") @db.Text
  keysSavedAtTest   DateTime? @map("keys_saved_at_test")
  keysSavedAtLive   DateTime? @map("keys_saved_at_live")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("stripe_settings")
}

model StripeWebhookEvent {
  id String @id @default(cuid())

  eventId   String @unique @map("event_id")
  eventType String @map("event_type")
  livemode  Boolean @default(false)

  payloadJson Json @map("payload_json")

  processedStatus StripeWebhookProcessedStatus @default(pending) @map("processed_status")
  processedAt     DateTime? @map("processed_at")
  errorMessage    String? @map("error_message") @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  @@index([eventType])
  @@index([processedStatus])
  @@index([createdAt])
  @@map("stripe_webhook_events")
}

// -----------------------------------------------------------------------------
// CourseAccess — Kurs-/Workshop-Zugriff nach Zahlung (vorbereitet)
// -----------------------------------------------------------------------------
model CourseAccess {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String  @map("product_id") @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  status CourseAccessStatus @default(pending)
  source CourseAccessSource

  checkoutIntentId String?         @map("checkout_intent_id") @db.Uuid
  checkoutIntent   CheckoutIntent? @relation(fields: [checkoutIntentId], references: [id], onDelete: SetNull)

  accountingPositionId String? @map("accounting_position_id") @db.Uuid

  grantedAt DateTime? @map("granted_at")
  expiresAt DateTime? @map("expires_at")
  pendingAccessUntil DateTime? @map("pending_access_until")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, productId])
  @@index([status])
  @@index([checkoutIntentId])
  @@map("course_access")
}

// =============================================================================
// Rechnungen (Schritt 19–20)
// =============================================================================

/// Status einer Rechnung
enum InvoiceStatus {
  draft
  issued
  paid
  cancelled
  refunded
}

/// Zähler für fortlaufende Rechnungsnummern
model InvoiceSequence {
  id String @id @default("default")

  currentNumber Int @default(0) @map("current_number")
  prefix        String @default("RE")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("invoice_sequences")
}

/// Rechnung zu einer Buchhaltungsposition (Snapshot für Druck/PDF)
model Invoice {
  id String @id @default(uuid()) @db.Uuid

  invoiceNumber  String @unique @map("invoice_number")
  sequenceNumber Int    @map("sequence_number")
  sequenceYear   Int    @map("sequence_year")

  accountingPositionId String             @unique @map("accounting_position_id") @db.Uuid
  accountingPosition   AccountingPosition @relation(fields: [accountingPositionId], references: [id], onDelete: Restrict)

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  invoiceDate DateTime @map("invoice_date")
  serviceDate DateTime @map("service_date")
  dueDate     DateTime? @map("due_date")

  status InvoiceStatus @default(issued)

  paymentStatus AccountingPositionPaymentStatus @map("payment_status")

  /// Kundendaten zum Rechnungszeitpunkt (JSON-Snapshot)
  customerSnapshot Json @map("customer_snapshot")

  productType AccountingProductType @map("product_type")
  productName String @map("product_name")

  netAmount   Decimal @map("net_amount") @db.Decimal(12, 2)
  taxRate     Decimal @map("tax_rate") @db.Decimal(5, 2)
  taxAmount   Decimal @map("tax_amount") @db.Decimal(12, 2)
  grossAmount Decimal @map("gross_amount") @db.Decimal(12, 2)
  currency    String  @default("EUR")

  noteText String? @db.Text @map("note_text")

  cancelledAt DateTime? @map("cancelled_at")

  creditNote CreditNote?

  createdByUserId String? @map("created_by_user_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([invoiceNumber])
  @@index([invoiceDate])
  @@index([status])
  @@map("invoices")
}

/// Zähler für fortlaufende Gutschriftsnummern
model CreditNoteSequence {
  id String @id @default("default")

  currentNumber Int @default(0) @map("current_number")
  prefix        String @default("GS")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("credit_note_sequences")
}

/// Gutschrift zu einer stornierten/erstatteten Rechnung
model CreditNote {
  id String @id @default(uuid()) @db.Uuid

  creditNoteNumber String @unique @map("credit_note_number")
  sequenceNumber   Int    @map("sequence_number")
  sequenceYear     Int    @map("sequence_year")

  invoiceId String  @unique @map("invoice_id") @db.Uuid
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  creditNoteDate DateTime @map("credit_note_date")

  referenceInvoiceNumber String @map("reference_invoice_number")

  customerSnapshot Json @map("customer_snapshot")

  productType AccountingProductType @map("product_type")
  productName String @map("product_name")

  netAmount   Decimal @map("net_amount") @db.Decimal(12, 2)
  taxRate     Decimal @map("tax_rate") @db.Decimal(5, 2)
  taxAmount   Decimal @map("tax_amount") @db.Decimal(12, 2)
  grossAmount Decimal @map("gross_amount") @db.Decimal(12, 2)
  currency    String  @default("EUR")

  noteText String? @db.Text @map("note_text")

  createdByUserId String? @map("created_by_user_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([creditNoteNumber])
  @@index([creditNoteDate])
  @@map("credit_notes")
}

// =============================================================================
// Kursplattform (Schritt 21)
// =============================================================================

/// Kurstyp
enum CourseType {
  minikurs
  zertifikatskurs
}

/// Veröffentlichungsstatus eines Kurses
enum CourseStatus {
  draft
  published
  archived
}

/// Lektionstyp
enum CourseLessonType {
  video
  text
  download
  recipe
  certificate
}

/// Zertifikatstyp pro Kurs
enum CourseCertificateType {
  none
  participation
  achievement
  masterclass
}

/// Status eines Nutzer-Zertifikats
enum UserCertificateStatus {
  locked
  available
  issued
  revoked
}

/// Kurs mit Modulen und Lektionen (immer kostenpflichtig)
model Course {
  id String @id @default(uuid()) @db.Uuid

  slug  String @unique
  title String
  subtitle    String?
  /// Kurzbeschreibung für Karten und Katalog (Plaintext)
  shortDescription String? @db.Text @map("short_description")
  /// Ausführliche Beschreibung (Markdown, sicher gerendert)
  description String? @db.Text
  /// Kursvoraussetzungen (Markdown)
  prerequisites String? @db.Text
  /// Was der Teilnehmer zuhause benötigt (Markdown)
  requiredEquipment String? @db.Text @map("required_equipment")
  learningGoals String? @db.Text @map("learning_goals")

  courseType CourseType @map("course_type")
  status     CourseStatus @default(draft)

  certificateType CourseCertificateType @default(participation) @map("certificate_type")
  /// Bewusster Admin-Override: Minikurs darf ein vollwertiges Zertifikat ausstellen
  certificateOverride Boolean @default(false) @map("certificate_override")
  estimatedMinutes Int? @map("estimated_minutes")
  sortOrder Int @default(0) @map("sort_order")

  /// Preis in Cent (null = noch nicht gesetzt, 0 = bewusst kostenlos)
  priceCents    Int?   @map("price_cents")
  priceCurrency String @default("EUR") @map("price_currency")

  /// Hervorhebung auf der Startseite (Bereich 1)
  featuredOnHomepage Boolean @default(false) @map("featured_on_homepage")
  /// Sortierung innerhalb der hervorgehobenen Startseiten-Kurse (ASC)
  homepageSortOrder  Int     @default(100) @map("homepage_sort_order")

  coverStorageKey String? @map("cover_storage_key")
  coverFileName   String? @map("cover_file_name")

  productId String?  @unique @map("product_id") @db.Uuid
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  /// Foren für Kursteilnehmer automatisch bereitstellen
  forumsEnabled Boolean @default(false) @map("forums_enabled")

  courseGroupId String? @map("course_group_id") @db.Uuid
  courseGroup   CourseGroup? @relation(fields: [courseGroupId], references: [id], onDelete: SetNull)

  courseSubgroupId String? @map("course_subgroup_id") @db.Uuid
  courseSubgroup   CourseSubgroup? @relation(fields: [courseSubgroupId], references: [id], onDelete: SetNull)

  publishedAt DateTime? @map("published_at")

  modules          CourseModule[]
  userAccess       UserCourseAccess[]
  membershipRules  MembershipCourseRule[]
  certificates     UserCourseCertificate[]
  forums           Forum[]
  reviews          CourseReview[]
  productRecommendationLinks ProductRecommendationCourseLink[]
  learningPathAssignments CourseLearningPathAssignment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([courseType])
  @@index([sortOrder])
  @@index([featuredOnHomepage, homepageSortOrder])
  @@index([createdAt])
  @@index([courseGroupId])
  @@index([courseSubgroupId])
  @@map("courses")
}

/// Zuordnung Kurs ↔ Lernpfad (ein Kurs kann mehreren Lernpfaden angehören)
model CourseLearningPathAssignment {
  id String @id @default(uuid()) @db.Uuid

  courseId String @map("course_id") @db.Uuid
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  courseGroupId String      @map("course_group_id") @db.Uuid
  courseGroup   CourseGroup @relation(fields: [courseGroupId], references: [id], onDelete: Cascade)

  courseSubgroupId String?         @map("course_subgroup_id") @db.Uuid
  courseSubgroup   CourseSubgroup? @relation(fields: [courseSubgroupId], references: [id], onDelete: SetNull)

  sortOrder Int     @default(100) @map("sort_order")
  isPrimary Boolean @default(false) @map("is_primary")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([courseId, courseGroupId])
  @@index([courseGroupId])
  @@index([courseSubgroupId])
  @@map("course_learning_path_assignments")
}

/// Pflichtmodul innerhalb eines Kurses
model CourseModule {
  id String @id @default(uuid()) @db.Uuid

  courseId String @map("course_id") @db.Uuid
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  title       String
  description String? @db.Text
  sortOrder   Int     @default(0) @map("sort_order")

  lessons CourseLesson[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([courseId])
  @@index([courseId, sortOrder])
  @@map("course_modules")
}

/// Pflichtlektion innerhalb eines Moduls
model CourseLesson {
  id String @id @default(uuid()) @db.Uuid

  moduleId String       @map("module_id") @db.Uuid
  module   CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  slug  String
  title String
  description String? @db.Text

  lessonType CourseLessonType @map("lesson_type")
  sortOrder  Int              @default(0) @map("sort_order")
  durationMinutes Int? @map("duration_minutes")

  textContent String? @db.Text @map("text_content")

  /// Optionaler Ressourcen-Link (https://…), z. B. zu Shop, PDF oder Website
  externalUrl String? @map("external_url") @db.Text
  /// Anzeigetext für den Ressourcen-Link
  externalUrlLabel String? @map("external_url_label")

  /// Nur Vimeo-Video-ID (kein direkter URL-Leak)
  vimeoVideoId String? @map("vimeo_video_id")

  downloadStorageKey String? @map("download_storage_key")
  downloadFileName   String? @map("download_file_name")

  recipeId    String? @map("recipe_id") @db.Uuid
  recipeTitle String? @map("recipe_title")
  recipeContent Json? @map("recipe_content")

  progress CourseLessonProgress[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([moduleId, slug])
  @@index([moduleId])
  @@index([moduleId, sortOrder])
  @@map("course_lessons")
}

/// Fortschritt pro Nutzer und Lektion
model CourseLessonProgress {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  lessonId String       @map("lesson_id") @db.Uuid
  lesson   CourseLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  completed   Boolean   @default(false)
  completedAt DateTime? @map("completed_at")
  lastViewedAt DateTime? @map("last_viewed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("course_lesson_progress")
}

/// Kurszugriff auf Nutzerebene (Kauf, Buchhaltung, Admin, Mitgliedschaft)
model UserCourseAccess {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  courseId String @map("course_id") @db.Uuid
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  status CourseAccessStatus @default(active)
  source CourseAccessSource

  grantedAt DateTime? @map("granted_at")
  expiresAt DateTime? @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  note String? @db.Text

  courseAccessId String? @unique @map("course_access_id") @db.Uuid

  adminGrantedByUserId String? @map("admin_granted_by_user_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, courseId])
  @@index([status])
  @@index([courseId])
  @@map("user_course_access")
}

/// Mitgliedschafts-Regel: Bonuskurs für Jahresabo o. ä.
model MembershipCourseRule {
  id String @id @default(uuid()) @db.Uuid

  membershipRole MembershipRole @map("membership_role")
  courseId       String         @map("course_id") @db.Uuid
  course         Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)

  /// null = alle Abrechnungsperioden, yearly = nur Jahresmitgliedschaft
  billingPeriod BillingPeriod? @map("billing_period")

  active Boolean @default(true)
  note   String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([membershipRole, courseId])
  @@index([membershipRole])
  @@index([courseId])
  @@map("membership_course_rules")
}

/// Nutzer-Zertifikat (vorbereitet, nach Kursabschluss freischaltbar)
model UserCourseCertificate {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  courseId String @map("course_id") @db.Uuid
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  certificateType CourseCertificateType @map("certificate_type")
  status          UserCertificateStatus @default(locked)

  issuedAt DateTime? @map("issued_at")
  certificateNumber String? @unique @map("certificate_number")

  verificationToken String? @unique @map("verification_token")
  verificationUrl   String? @map("verification_url")
  pdfGeneratedAt    DateTime? @map("pdf_generated_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  publicShare PublicShare?

  @@unique([userId, courseId])
  @@index([status])
  @@index([certificateNumber])
  @@map("user_course_certificates")
}

