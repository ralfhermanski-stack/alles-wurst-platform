// -----------------------------------------------------------------------------
// Support-Tickets
// -----------------------------------------------------------------------------

enum SupportTicketStatus {
  open
  in_progress
  waiting_user
  resolved
  closed
}

enum SupportTicketPriority {
  normal
  important
  urgent
}

enum SupportTicketWaitingOn {
  admin
  user
}

enum SupportTicketEventType {
  created
  status_changed
  assigned
  reassigned
  public_reply
  internal_note
  user_reply
  resolved
  closed
  reopened
  rating
  attachment_added
  reminder_sent
  escalated
  anonymized
}

enum SupportTicketMessageAuthorType {
  user
  staff
}

/// Admin-verwaltete Ticket-Kategorien
model SupportTicketCategory {
  id String @id @default(uuid()) @db.Uuid

  name        String
  slug        String  @unique
  description String? @db.Text
  sortOrder   Int     @default(0) @map("sort_order")
  isActive    Boolean @default(true) @map("is_active")
  isMasterSupport Boolean @default(false) @map("is_master_support")

  tickets   SupportTicket[]
  templates SupportReplyTemplate[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("support_ticket_categories")
}

/// Support-Ticket
model SupportTicket {
  id String @id @default(uuid()) @db.Uuid

  ticketNumber String @unique @map("ticket_number")

  userId String @map("user_id") @db.Uuid
  user   User   @relation("SupportTicketCreator", fields: [userId], references: [id], onDelete: Cascade)

  categoryId String               @map("category_id") @db.Uuid
  category   SupportTicketCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  assignedToUserId String? @map("assigned_to_user_id") @db.Uuid
  assignedTo       User?   @relation("SupportTicketAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  subject  String
  status   SupportTicketStatus   @default(open)
  priority SupportTicketPriority @default(normal)
  waitingOn SupportTicketWaitingOn @default(admin) @map("waiting_on")

  isOverdue           Boolean @default(false) @map("is_overdue")
  unassignedAlertSent Boolean @default(false) @map("unassigned_alert_sent")

  lastStaffReplyAt DateTime? @map("last_staff_reply_at")
  lastUserReplyAt  DateTime? @map("last_user_reply_at")
  resolvedAt       DateTime? @map("resolved_at")
  closedAt         DateTime? @map("closed_at")
  userReminderAt   DateTime? @map("user_reminder_at")
  autoCloseAt      DateTime? @map("auto_close_at")

  userUnreadCount Int     @default(0) @map("user_unread_count")
  userHasReminder Boolean @default(false) @map("user_has_reminder")

  rating        Int?    @map("rating")
  ratingComment String? @map("rating_comment") @db.Text
  closureNote   String? @map("closure_note") @db.Text

  anonymizedAt DateTime? @map("anonymized_at")

  withdrawalRequestId String? @unique @map("withdrawal_request_id") @db.Uuid
  withdrawalRequest   WithdrawalRequest? @relation(fields: [withdrawalRequestId], references: [id], onDelete: SetNull)

  privacyRequestId String? @unique @map("privacy_request_id") @db.Uuid
  privacyRequest   PrivacyRequest? @relation(fields: [privacyRequestId], references: [id], onDelete: SetNull)

  messages      SupportTicketMessage[]
  internalNotes SupportTicketInternalNote[]
  attachments   SupportTicketAttachment[]
  events        SupportTicketEvent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, status, createdAt])
  @@index([assignedToUserId, status])
  @@index([status, priority, createdAt])
  @@index([isOverdue, status])
  @@map("support_tickets")
}

/// Öffentliche Nachricht im Ticketverlauf (User + Staff)
model SupportTicketMessage {
  id String @id @default(uuid()) @db.Uuid

  ticketId String        @map("ticket_id") @db.Uuid
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  authorUserId String @map("author_user_id") @db.Uuid
  author       User   @relation(fields: [authorUserId], references: [id], onDelete: Cascade)

  authorType SupportTicketMessageAuthorType @map("author_type")
  body       String @db.Text

  isReadByUser Boolean @default(false) @map("is_read_by_user")

  attachments SupportTicketAttachment[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([ticketId, createdAt])
  @@map("support_ticket_messages")
}

/// Interne Notiz — nur für Staff sichtbar
model SupportTicketInternalNote {
  id String @id @default(uuid()) @db.Uuid

  ticketId String        @map("ticket_id") @db.Uuid
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  authorUserId String @map("author_user_id") @db.Uuid
  author       User   @relation(fields: [authorUserId], references: [id], onDelete: Cascade)

  body String @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  @@index([ticketId, createdAt])
  @@map("support_ticket_internal_notes")
}

/// Dateianhang an Ticket oder Nachricht
model SupportTicketAttachment {
  id String @id @default(uuid()) @db.Uuid

  ticketId String        @map("ticket_id") @db.Uuid
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  messageId String?              @map("message_id") @db.Uuid
  message   SupportTicketMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  uploadedByUserId String @map("uploaded_by_user_id") @db.Uuid
  uploadedBy       User   @relation("SupportAttachmentUploader", fields: [uploadedByUserId], references: [id], onDelete: Cascade)

  storageKey String @map("storage_key")
  fileName   String @map("file_name")
  mimeType   String @map("mime_type")
  sizeBytes  Int    @map("size_bytes")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([ticketId])
  @@map("support_ticket_attachments")
}

/// Audit-Log / Ticketverlauf
model SupportTicketEvent {
  id String @id @default(uuid()) @db.Uuid

  ticketId String        @map("ticket_id") @db.Uuid
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  actorUserId String? @map("actor_user_id") @db.Uuid
  actor       User?   @relation("SupportTicketEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  eventType SupportTicketEventType @map("event_type")
  summary   String @db.Text
  metadata  Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([ticketId, createdAt])
  @@map("support_ticket_events")
}

/// Antwortvorlagen für Staff
model SupportReplyTemplate {
  id String @id @default(uuid()) @db.Uuid

  title    String
  body     String @db.Text
  sortOrder Int   @default(0) @map("sort_order")
  isActive Boolean @default(true) @map("is_active")

  categoryId String?               @map("category_id") @db.Uuid
  category   SupportTicketCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("support_reply_templates")
}

/// Zähler für Ticketnummern pro Jahr (AW-T-2026-000001)
model SupportTicketCounter {
  year       Int @id
  lastNumber Int @default(0) @map("last_number")

  @@map("support_ticket_counters")
}

