  manual
}

enum PageSeoPageType {
  static
  course
  product
  course_group
  course_subgroup
  blog_category
  blog_tag
}

enum PageSeoGenerationStatus {
  pending
  queued
  processing
  pending_review
  completed
  failed
  skipped
  stale
}

model PageSeo {
  id String @id @default(cuid())

  routeKey String @unique @map("route_key")
  path     String
  pageType PageSeoPageType @map("page_type")
  entityId String? @map("entity_id")

  seoSource PageSeoSource @default(auto) @map("seo_source")

  metaTitle       String? @map("meta_title")
  metaDescription String? @map("meta_description") @db.Text
  keywords        Json    @default("[]")

  ogTitle       String? @map("og_title")
  ogDescription String? @map("og_description") @db.Text
  ogImage       String? @map("og_image")

  twitterTitle       String? @map("twitter_title")
  twitterDescription String? @map("twitter_description") @db.Text

  canonicalUrl String? @map("canonical_url")
  jsonLd       Json?   @map("json_ld")

  aiSummary        String? @map("ai_summary") @db.Text
  aiMainTopic      String? @map("ai_main_topic")
  aiEntities       Json    @default("[]") @map("ai_entities")
  aiAudience       String? @map("ai_audience")
  aiExpertise      String? @map("ai_expertise")
  semanticKeywords Json    @default("[]") @map("semantic_keywords")

  /// KI-Vorschläge — werden erst nach Admin-Freigabe in die Live-Felder übernommen
  seoDraft Json? @map("seo_draft")

  contentHash          String? @map("content_hash")
  lastGeneratedAt      DateTime? @map("last_generated_at")
  lastContentChangeAt  DateTime? @map("last_content_change_at")
