/// Newsletter-Anmeldungen von der Wartungsseite
model MaintenanceNewsletterSignup {
  id String @id @default(uuid()) @db.Uuid

  email  String
  source String @default("maintenance")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([email])
