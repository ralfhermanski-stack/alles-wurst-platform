enum LegalDocumentType {
  IMPRINT
  PRIVACY_POLICY
  TERMS_AND_CONDITIONS
  WITHDRAWAL_POLICY
  WITHDRAWAL_FORM
  COOKIE_POLICY
  FORUM_RULES
  OPTIONAL_OTHER
}

enum LegalDocumentStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  OUTDATED
  ERROR
  ARCHIVED
}

enum LegalDocumentSourceType {
  API
  HTML_FETCH
  TEXT_FETCH
  WEBHOOK
  MANUAL_IMPORT
  MANUAL_EDIT
}

enum LegalDocumentIntegrationMode {
  API_SYNC
  HTML_SYNC
  TEXT_SYNC
  WEBHOOK
  MANUAL
  IFRAME_PREVIEW_ONLY
}

enum LegalDocumentContentFormat {
  HTML
  MARKDOWN
  PLAIN_TEXT
}

enum LegalDocumentVersionStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  ARCHIVED
}

enum LegalSyncStatus {
  RUNNING
  SUCCESS
  UNCHANGED
  FAILED
}

enum LegalProductType {
  DIGITAL_CONTENT
  DIGITAL_SERVICE
  MEMBERSHIP
  LIVE_SERVICE
  MIXED_CONTRACT
  FREE_CONTENT
}

enum CheckoutConsentType {
  TERMS
  PRIVACY_ACKNOWLEDGEMENT
  IMMEDIATE_ACCESS
  WITHDRAWAL_LOSS_ACKNOWLEDGEMENT
}

enum CourseAccessMode {
  IMMEDIATE
  DELAYED
}

enum WithdrawalRequestStatus {
  RECEIVED
  UNDER_REVIEW
  ADDITIONAL_INFORMATION_REQUIRED
  ACCEPTED
  PARTIALLY_ACCEPTED
  REJECTED
  REFUNDED
  CLOSED
}

enum WithdrawalRequestSource {
  PUBLIC_FORM
  USER_ACCOUNT
}

model LegalDocument {
  id String @id @default(uuid()) @db.Uuid

  type   LegalDocumentType
  title  String
  slug   String @unique
  locale String @default("de")

  sourceType      LegalDocumentSourceType      @default(MANUAL_EDIT) @map("source_type")
  providerName    String?                      @map("provider_name")
  externalDocumentId String?                   @map("external_document_id")
  externalUrl     String?                      @map("external_url")
  integrationMode LegalDocumentIntegrationMode @default(MANUAL) @map("integration_mode")
  contentFormat   LegalDocumentContentFormat   @default(HTML) @map("content_format")

  currentPublishedVersionId String? @unique @map("current_published_version_id") @db.Uuid

  status LegalDocumentStatus @default(DRAFT)

  autoPublish        Boolean @default(false) @map("auto_publish")
  allowManualEditing Boolean @default(true) @map("allow_manual_editing")
  publicVisible      Boolean @default(true) @map("public_visible")
  seoIndex           Boolean @default(true) @map("seo_index")

  lastCheckedAt         DateTime? @map("last_checked_at")
  lastSuccessfulSyncAt  DateTime? @map("last_successful_sync_at")
  lastErrorAt           DateTime? @map("last_error_at")
  lastErrorMessage      String?   @map("last_error_message") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  versions               LegalDocumentVersion[] @relation("DocumentVersions")
  currentPublishedVersion LegalDocumentVersion? @relation("PublishedVersion", fields: [currentPublishedVersionId], references: [id], onDelete: SetNull)
  syncLogs               LegalDocumentSyncLog[]
  credentials            LegalDocumentCredential[]

  @@index([type, status])
  @@index([publicVisible, status])
  @@map("legal_documents")
}

model LegalDocumentVersion {
  id String @id @default(uuid()) @db.Uuid

  documentId String        @map("document_id") @db.Uuid
  document   LegalDocument @relation("DocumentVersions", fields: [documentId], references: [id], onDelete: Cascade)

  versionNumber  Int     @map("version_number")
  externalVersion String? @map("external_version")

  content          String @db.Text
  sanitizedContent String @map("sanitized_content") @db.Text
  checksum         String

  status LegalDocumentVersionStatus @default(DRAFT)

  validFrom  DateTime? @map("valid_from")
  validUntil DateTime? @map("valid_until")

  importedAt   DateTime  @default(now()) @map("imported_at")
  importedById String?   @map("imported_by_id") @db.Uuid
  importedBy   User?     @relation("LegalVersionImporter", fields: [importedById], references: [id], onDelete: SetNull)

  publishedAt   DateTime? @map("published_at")
  publishedById String?   @map("published_by_id") @db.Uuid
  publishedBy   User?     @relation("LegalVersionPublisher", fields: [publishedById], references: [id], onDelete: SetNull)

  sourceMetadata Json? @map("source_metadata")
  changeSummary  String? @map("change_summary") @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  publishedForDocument LegalDocument? @relation("PublishedVersion")
  userAcceptances      UserLegalAcceptance[]

  @@unique([documentId, versionNumber])
  @@index([documentId, status])
  @@map("legal_document_versions")
}

model UserLegalAcceptance {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  acceptanceType String @map("acceptance_type")

  documentVersionId String?              @map("document_version_id") @db.Uuid
  documentVersion   LegalDocumentVersion? @relation(fields: [documentVersionId], references: [id], onDelete: SetNull)
  documentChecksum  String               @map("document_checksum")
  labelText         String               @map("label_text") @db.Text

  acceptedAt DateTime @default(now()) @map("accepted_at")
  validUntil DateTime @map("valid_until")

  @@index([userId, acceptanceType, validUntil])
  @@index([userId, acceptanceType, acceptedAt])
  @@map("user_legal_acceptances")
}

model LegalDocumentSyncLog {
  id String @id @default(uuid()) @db.Uuid

  documentId String?        @map("document_id") @db.Uuid
  document   LegalDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  status LegalSyncStatus

  startedAt  DateTime  @default(now()) @map("started_at")
  finishedAt DateTime? @map("finished_at")

  contentChanged   Boolean @default(false) @map("content_changed")
  previousChecksum String? @map("previous_checksum")
  newChecksum      String? @map("new_checksum")

  errorCode    String? @map("error_code")
  errorMessage String? @map("error_message") @db.Text

  triggeredBy       String  @default("cron") @map("triggered_by")
  triggeredByUserId String? @map("triggered_by_user_id") @db.Uuid

  @@index([startedAt])
  @@index([documentId])
  @@map("legal_document_sync_logs")
}

model LegalDocumentCredential {
  id String @id @default(uuid()) @db.Uuid

  documentId String?        @map("document_id") @db.Uuid
  document   LegalDocument? @relation(fields: [documentId], references: [id], onDelete: Cascade)

  provider        String
  credentialType  String @map("credential_type")
  encryptedValue  String @map("encrypted_value") @db.Text
  expiresAt       DateTime? @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([provider, credentialType, documentId])
  @@map("legal_document_credentials")
}

model CheckoutLegalConsent {
  id String @id @default(uuid()) @db.Uuid

  checkoutIntentId String         @map("checkout_intent_id") @db.Uuid
  checkoutIntent   CheckoutIntent @relation(fields: [checkoutIntentId], references: [id], onDelete: Cascade)

  consentType CheckoutConsentType @map("consent_type")
  accepted    Boolean
  labelText   String              @map("label_text") @db.Text

  documentVersionId String? @map("document_version_id") @db.Uuid
  documentChecksum  String? @map("document_checksum")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([checkoutIntentId])
  @@map("checkout_legal_consents")
}

model PurchaseLegalRecord {
  id String @id @default(uuid()) @db.Uuid

  checkoutIntentId String         @unique @map("checkout_intent_id") @db.Uuid
  checkoutIntent   CheckoutIntent @relation(fields: [checkoutIntentId], references: [id], onDelete: Cascade)

  userId String @map("user_id") @db.Uuid
  accountingPositionId String? @map("accounting_position_id") @db.Uuid

  termsVersionId           String? @map("terms_version_id") @db.Uuid
  privacyVersionId         String? @map("privacy_version_id") @db.Uuid
  withdrawalPolicyVersionId String? @map("withdrawal_policy_version_id") @db.Uuid

  termsChecksum           String? @map("terms_checksum")
  privacyChecksum         String? @map("privacy_checksum")
  withdrawalPolicyChecksum String? @map("withdrawal_policy_checksum")

  immediateAccessConsented Boolean @default(false) @map("immediate_access_consented")
  withdrawalLossAcknowledged Boolean @default(false) @map("withdrawal_loss_acknowledged")
  accessMode CourseAccessMode @default(DELAYED) @map("access_mode")
  pendingAccessUntil DateTime? @map("pending_access_until")

  consentSnapshot Json @default("{}") @map("consent_snapshot")
  legalProductType LegalProductType? @map("legal_product_type")

  /// Revisionssicherer Nachweis zum Zustimmungszeitpunkt
  clientIpHash       String? @map("client_ip_hash")
  userAgentHash      String? @map("user_agent_hash")
  orderNumber        String? @map("order_number")
  productName        String? @map("product_name")
  productSlug        String? @map("product_slug")
  membershipRole     String? @map("membership_role")
  consentTextVersion String? @map("consent_text_version")

  recordedAt DateTime @default(now()) @map("recorded_at")

  orderLegalDocuments OrderLegalDocument[]

  @@index([userId])
  @@index([orderNumber])
  @@map("purchase_legal_records")
}

model WithdrawalRequest {
  id String @id @default(uuid()) @db.Uuid

  withdrawalNumber String @unique @map("withdrawal_number")

  userId String? @map("user_id") @db.Uuid
  user   User?   @relation("WithdrawalUser", fields: [userId], references: [id], onDelete: SetNull)

  firstName String @map("first_name")
  lastName  String @map("last_name")
  email     String

  orderReference String? @map("order_reference")
  productName    String? @map("product_name")
  orderDate      DateTime? @map("order_date")
  contractDate   DateTime? @map("contract_date")
  message        String? @db.Text

  status WithdrawalRequestStatus @default(RECEIVED)

  assignedToId String? @map("assigned_to_id") @db.Uuid
  assignedTo   User?   @relation("WithdrawalAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  rejectionReason      String? @map("rejection_reason") @db.Text
  legalBasisReference  String? @map("legal_basis_reference") @db.Text
  internalNotes        String? @map("internal_notes") @db.Text

  purchaseLegalRecordId String? @map("purchase_legal_record_id") @db.Uuid
  accountingPositionId  String? @map("accounting_position_id") @db.Uuid
  checkoutIntentId      String? @map("checkout_intent_id") @db.Uuid

  source WithdrawalRequestSource @default(PUBLIC_FORM)
  declarationText String? @map("declaration_text") @db.Text
  courseAccessStatus String? @map("course_access_status")
  consentSnapshot Json? @map("consent_snapshot")
  ticketCreationFailed Boolean @default(false) @map("ticket_creation_failed")

  stripeRefundId        String? @map("stripe_refund_id")

  receivedAt DateTime @default(now()) @map("received_at")
  resolvedAt DateTime? @map("resolved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  supportTicket SupportTicket?

  @@index([status])
  @@index([email])
  @@index([userId])
  @@index([accountingPositionId])
  @@map("withdrawal_requests")
}

enum OrderLegalDocumentType {
  TERMS_AND_CONDITIONS
  WITHDRAWAL_POLICY
  WITHDRAWAL_FORM
  ORDER_CONFIRMATION
  MEMBERSHIP_TERMS
  PRODUCT_SPECIFIC
}

enum OrderLegalDocumentStatus {
  PENDING
  GENERATED
  FAILED
  SENT
}

model OrderLegalDocument {
  id String @id @default(uuid()) @db.Uuid

  accountingPositionId String @map("accounting_position_id") @db.Uuid
  checkoutIntentId     String? @map("checkout_intent_id") @db.Uuid
  purchaseLegalRecordId String? @map("purchase_legal_record_id") @db.Uuid
  purchaseLegalRecord   PurchaseLegalRecord? @relation(fields: [purchaseLegalRecordId], references: [id], onDelete: SetNull)

  legalDocumentType OrderLegalDocumentType @map("legal_document_type")
  sourceDocumentId  String? @map("source_document_id") @db.Uuid
  sourceVersionId   String? @map("source_version_id") @db.Uuid

  title        String
  versionLabel String? @map("version_label")
  checksum     String
  storageKey   String? @map("storage_key")
  mimeType     String  @default("application/pdf") @map("mime_type")
  sizeBytes    Int?    @map("size_bytes")
  status       OrderLegalDocumentStatus @default(PENDING)
  errorMessage String? @map("error_message") @db.Text

  generatedAt DateTime? @map("generated_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@unique([accountingPositionId, legalDocumentType])
  @@index([checkoutIntentId])
  @@map("order_legal_documents")
}

enum PrivacyRequestType {
  ACCESS
  RECTIFICATION
  DELETION
  RESTRICTION
  OBJECTION
  PORTABILITY
  EXPORT
}

enum PrivacyRequestStatus {
  REQUESTED
  EMAIL_CONFIRMATION_PENDING
  CONFIRMED
  IDENTITY_REVIEW
  UNDER_REVIEW
  PARTIALLY_FULFILLED
  FULFILLED
  REJECTED
  CANCELLED
}

enum AccountDeletionPlanStatus {
  DRAFT
  CONFIRMED
  BLOCKED
  SCHEDULED
  EXECUTING
  PARTIALLY_COMPLETED
  COMPLETED
  FAILED
}

enum DataExportRequestStatus {
  REQUESTED
  PROCESSING
  READY
  DOWNLOADED
  EXPIRED
  FAILED
}

model UserAccountMessage {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  messageType String @map("message_type")
  title       String
  body        String @db.Text
  linkUrl     String? @map("link_url")
  readAt      DateTime? @map("read_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, readAt])
  @@map("user_account_messages")
}

model PrivacyRequest {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  requestNumber String @unique @map("request_number")
  type          PrivacyRequestType
  status        PrivacyRequestStatus @default(REQUESTED)

  userMessage   String? @map("user_message") @db.Text
  responseText  String? @map("response_text") @db.Text
  rejectionReason String? @map("rejection_reason") @db.Text
  internalNotes String? @map("internal_notes") @db.Text

  emailConfirmationTokenHash String? @map("email_confirmation_token_hash")
  emailConfirmationExpiresAt DateTime? @map("email_confirmation_expires_at")
  emailConfirmedAt DateTime? @map("email_confirmed_at")
  finalConfirmedAt DateTime? @map("final_confirmed_at")

  assignedToId String? @map("assigned_to_id") @db.Uuid
  assignedTo   User?   @relation("PrivacyAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  dueAt       DateTime? @map("due_at")
  completedAt DateTime? @map("completed_at")

  supportTicket SupportTicket?

  requestedAt DateTime @default(now()) @map("requested_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  deletionPlan AccountDeletionPlan?
  dataExport     DataExportRequest?

  @@index([userId, status])
  @@index([status, dueAt])
  @@map("privacy_requests")
}

model AccountDeletionPlan {
  id String @id @default(uuid()) @db.Uuid

  privacyRequestId String @unique @map("privacy_request_id") @db.Uuid
  privacyRequest   PrivacyRequest @relation(fields: [privacyRequestId], references: [id], onDelete: Cascade)

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status AccountDeletionPlanStatus @default(DRAFT)

  deletableData      Json @default("[]") @map("deletable_data")
  anonymizableData   Json @default("[]") @map("anonymizable_data")
  retainedData       Json @default("[]") @map("retained_data")
  blockingItems      Json @default("[]") @map("blocking_items")
  retentionSchedule  Json @default("[]") @map("retention_schedule")

  calculatedAt DateTime? @map("calculated_at")
  executedAt   DateTime? @map("executed_at")

  /// Löschung ausführen ab (z. B. nach Mitgliedschafts-Ablauf)
  scheduledExecutionAt DateTime? @map("scheduled_execution_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, status])
  @@index([scheduledExecutionAt])
  @@map("account_deletion_plans")
}

model AccountDataRetention {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  dataCategory   String @map("data_category")
  reasonCode     String @map("reason_code")
  legalReference String? @map("legal_reference")
  retentionUntil DateTime? @map("retention_until")
  restrictedAt   DateTime? @map("restricted_at")
  deletedAt      DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, dataCategory])
  @@index([retentionUntil])
  @@map("account_data_retentions")
}

model DataExportRequest {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  privacyRequestId String? @unique @map("privacy_request_id") @db.Uuid
  privacyRequest   PrivacyRequest? @relation(fields: [privacyRequestId], references: [id], onDelete: SetNull)

  status DataExportRequestStatus @default(REQUESTED)
  storageKey String? @map("storage_key")
  expiresAt  DateTime? @map("expires_at")
  requestedAt DateTime @default(now()) @map("requested_at")
  generatedAt DateTime? @map("generated_at")
  downloadedAt DateTime? @map("downloaded_at")
  errorMessage String? @map("error_message") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, status])
  @@map("data_export_requests")
}

// =============================================================================
// Zentrales E-Mail-System
// =============================================================================

enum EmailProviderType {
  DEV
  DISABLED
  SMTP
  RESEND
  BREVO
  POSTMARK
  SES
  MAILGUN
  SENDGRID
}

enum EmailCategory {
  AUTH
  ACCOUNT
  SUPPORT
  TICKET
  COURSE
  CERTIFICATE
  ORDER
  PAYMENT
  BILLING
  MEMBERSHIP
  WITHDRAWAL
  PRIVACY
  CHALLENGE
  COMMUNITY
  MASTER_SUPPORT
  NEWSLETTER
  SECURITY
  SYSTEM
  ADMIN_MANUAL
}

enum EmailTemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum EmailMessageStatus {
  PENDING
  PROCESSING
  SENT
  DELIVERED
  FAILED
  RETRYING
  BOUNCED
  COMPLAINED
  CANCELLED
  SUPPRESSED
}

enum EmailPriority {
  CRITICAL
  HIGH
  NORMAL
  LOW
  BULK
}

enum EmailSuppressionReason {
  HARD_BOUNCE
  SOFT_BOUNCE_LIMIT
  COMPLAINT
  MANUAL_BLOCK
  INVALID_ADDRESS
  PROVIDER_SUPPRESSION
}

enum EmailDeliveryEventType {
  DELIVERED
  BOUNCED
  COMPLAINED
  REJECTED
  DEFERRED
  OPENED
  CLICKED
}

model EmailProviderConfig {
  id String @id @default(uuid()) @db.Uuid

  providerType EmailProviderType @map("provider_type")
  name         String
  active       Boolean @default(false)

  encryptedCredentials String? @map("encrypted_credentials") @db.Text
  settings             Json    @default("{}")

  lastTestedAt   DateTime? @map("last_tested_at")
  lastTestStatus String?   @map("last_test_status")
  lastError      String?   @map("last_error") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  senders  EmailSenderIdentity[]
  messages EmailMessage[]

  @@index([active, providerType])
  @@map("email_provider_configs")
}

model EmailSenderIdentity {
  id String @id @default(uuid()) @db.Uuid

  providerConfigId String @map("provider_config_id") @db.Uuid
  providerConfig   EmailProviderConfig @relation(fields: [providerConfigId], references: [id], onDelete: Restrict)

  internalName   String @map("internal_name")
  displayName    String @map("display_name")
  emailAddress   String @map("email_address")
  replyToAddress String? @map("reply_to_address")

  active        Boolean @default(true)
  verified      Boolean @default(false)
  defaultSender Boolean @default(false) @map("default_sender")
  allowedCategories EmailCategory[] @default([]) @map("allowed_categories")
  sortOrder     Int @default(0) @map("sort_order")

  dkimStatus  String? @map("dkim_status")
  spfStatus   String? @map("spf_status")
  dmarcStatus String? @map("dmarc_status")

  lastTestedAt        DateTime? @map("last_tested_at")
  lastSuccessfulSendAt DateTime? @map("last_successful_send_at")
  lastError           String?   @map("last_error") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  messages EmailMessage[]

  @@unique([emailAddress])
  @@index([active, verified])
  @@map("email_sender_identities")
}

model EmailTemplate {
  id String @id @default(uuid()) @db.Uuid

  key      String @unique
  name     String
  category EmailCategory
  locale   String @default("de")
  status   EmailTemplateStatus @default(DRAFT)

  activeVersionId String? @unique @map("active_version_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  versions EmailTemplateVersion[] @relation("TemplateVersions")
  activeVersion EmailTemplateVersion? @relation("ActiveTemplateVersion", fields: [activeVersionId], references: [id], onDelete: SetNull)

  @@index([category, status])
  @@map("email_templates")
}

model EmailTemplateVersion {
  id String @id @default(uuid()) @db.Uuid

  templateId String @map("template_id") @db.Uuid
  template   EmailTemplate @relation("TemplateVersions", fields: [templateId], references: [id], onDelete: Cascade)

  version          Int
  subject          String
  preheader        String? @map("preheader")
  htmlContent      String  @map("html_content") @db.Text
  textContent      String  @map("text_content") @db.Text
  allowedVariables Json    @default("[]") @map("allowed_variables")
  status           EmailTemplateStatus @default(DRAFT)

  createdById   String? @map("created_by_id") @db.Uuid
  createdBy     User?   @relation("EmailTemplateCreator", fields: [createdById], references: [id], onDelete: SetNull)
  publishedById String? @map("published_by_id") @db.Uuid
  publishedBy   User?   @relation("EmailTemplatePublisher", fields: [publishedById], references: [id], onDelete: SetNull)
  publishedAt   DateTime? @map("published_at")

  createdAt DateTime @default(now()) @map("created_at")

  activeForTemplate EmailTemplate? @relation("ActiveTemplateVersion")
  messages          EmailMessage[]

  @@unique([templateId, version])
  @@index([templateId, status])
  @@map("email_template_versions")
}

model EmailMessage {
  id String @id @default(uuid()) @db.Uuid

  recipientUserId String? @map("recipient_user_id") @db.Uuid
  recipientEmail  String  @map("recipient_email")
  recipientMasked String  @map("recipient_masked")

  senderIdentityId String? @map("sender_identity_id") @db.Uuid
  senderIdentity   EmailSenderIdentity? @relation(fields: [senderIdentityId], references: [id], onDelete: SetNull)
  providerConfigId String? @map("provider_config_id") @db.Uuid
  providerConfig   EmailProviderConfig? @relation(fields: [providerConfigId], references: [id], onDelete: SetNull)
  templateVersionId String? @map("template_version_id") @db.Uuid
  templateVersion   EmailTemplateVersion? @relation(fields: [templateVersionId], references: [id], onDelete: SetNull)

  category EmailCategory
  subjectSnapshot String @map("subject_snapshot")
  htmlSnapshot    String? @map("html_snapshot") @db.Text
  textSnapshot    String? @map("text_snapshot") @db.Text

  status   EmailMessageStatus @default(PENDING)
  priority EmailPriority      @default(NORMAL)

  scheduledAt DateTime? @map("scheduled_at")
  sentAt      DateTime? @map("sent_at")
  deliveredAt DateTime? @map("delivered_at")
  failedAt    DateTime? @map("failed_at")

  attempts         Int     @default(0)
  nextRetryAt      DateTime? @map("next_retry_at")
  lastErrorCode    String?   @map("last_error_code")
  lastErrorMessage String?   @map("last_error_message") @db.Text
  providerMessageId String?  @map("provider_message_id")

  relatedEntityType String? @map("related_entity_type")
  relatedEntityId   String? @map("related_entity_id")
  requestedByUserId String? @map("requested_by_user_id") @db.Uuid
  requestedBy       User?   @relation("EmailRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)

  isTest      Boolean @default(false) @map("is_test")
  hasAttachments Boolean @default(false) @map("has_attachments")
  createAccountMessage Boolean @default(false) @map("create_account_message")
  accountMessageType   String? @map("account_message_type")
  accountMessageTitle  String? @map("account_message_title")
  accountMessageBody   String? @map("account_message_body") @db.Text
  accountMessageLink   String? @map("account_message_link")

  processingLockAt DateTime? @map("processing_lock_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  attachments EmailAttachment[]
  events      EmailDeliveryEvent[]

  @@index([status, priority, nextRetryAt])
  @@index([recipientUserId, createdAt])
  @@index([category, status])
  @@index([relatedEntityType, relatedEntityId])
  @@map("email_messages")
}

model EmailAttachment {
  id String @id @default(uuid()) @db.Uuid

  emailMessageId String @map("email_message_id") @db.Uuid
  emailMessage   EmailMessage @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)

  filename  String
  mimeType  String @map("mime_type")
  sizeBytes Int    @map("size_bytes")
  storageKey String @map("storage_key")
  checksum  String?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([emailMessageId])
  @@map("email_attachments")
}

model EmailDeliveryEvent {
  id String @id @default(uuid()) @db.Uuid

  emailMessageId String @map("email_message_id") @db.Uuid
  emailMessage   EmailMessage @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)

  providerEventId String? @map("provider_event_id")
  eventType       EmailDeliveryEventType @map("event_type")
  occurredAt      DateTime @map("occurred_at")
  metadata        Json     @default("{}")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([emailMessageId, eventType])
  @@map("email_delivery_events")
}

model EmailSuppression {
  id String @id @default(uuid()) @db.Uuid

  emailHash String @unique @map("email_hash")
  reason    EmailSuppressionReason
  source    String
  active    Boolean @default(true)

  createdAt  DateTime @default(now()) @map("created_at")
  releasedAt DateTime? @map("released_at")

  @@index([active])
  @@map("email_suppressions")
}

model EmailPreference {
  id String @id @default(uuid()) @db.Uuid

  userId   String @map("user_id") @db.Uuid
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  category EmailCategory
  enabled  Boolean @default(true)
  source   String  @default("user")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, category])
  @@index([category, enabled])
  @@map("email_preferences")
}

model EmailCategoryConfig {
  id String @id @default(uuid()) @db.Uuid

  category EmailCategory @unique
  defaultSenderId String? @map("default_sender_id") @db.Uuid
  defaultReplyTo  String? @map("default_reply_to")
  defaultPriority EmailPriority @default(NORMAL) @map("default_priority")
  transactional   Boolean @default(true)
  marketing       Boolean @default(false)
  attachmentsAllowed Boolean @default(false) @map("attachments_allowed")
  alsoAccountMessage Boolean @default(false) @map("also_account_message")
  manualSendRoles  Json @default("[]") @map("manual_send_roles")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("email_category_configs")
}

// =============================================================================
// Social Sharing (nutzergenerierte Inhalte)
// =============================================================================

enum ShareContentType {
  CERTIFICATE
  DIPLOMA
  RECIPE
}

enum ShareStatus {
  ACTIVE
  DISABLED
  REVOKED
  ADMIN_BLOCKED
}

/// Öffentliche Freigabe für Zertifikate, Urkunden und eigene Rezepte
model PublicShare {
  id String @id @default(uuid()) @db.Uuid

  shareToken String @unique @map("share_token")

  contentType ShareContentType @map("content_type")
  ownerUserId String @map("owner_user_id") @db.Uuid
  owner       User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  certificateId String? @unique @map("certificate_id") @db.Uuid
  certificate   UserCourseCertificate? @relation(fields: [certificateId], references: [id], onDelete: Cascade)

  recipeId String? @map("recipe_id") @db.Uuid
  recipe   Recipe? @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  title String

  isPublic         Boolean @default(true) @map("is_public")
  linkOnly         Boolean @default(false) @map("link_only")
  showIngredients  Boolean @default(false) @map("show_ingredients")
  showInstructions Boolean @default(false) @map("show_instructions")

  status ShareStatus @default(ACTIVE)

  viewCount       Int @default(0) @map("view_count")
  whatsappShares  Int @default(0) @map("whatsapp_shares")
  facebookShares  Int @default(0) @map("facebook_shares")
  linkedinShares  Int @default(0) @map("linkedin_shares")
  twitterShares   Int @default(0) @map("twitter_shares")
  emailShares     Int @default(0) @map("email_shares")
  linkCopies      Int @default(0) @map("link_copies")

  consentAt DateTime? @map("consent_at")
  revokedAt DateTime? @map("revoked_at")
  adminNote String?   @map("admin_note") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([recipeId, ownerUserId])
  @@index([ownerUserId, status])
  @@index([contentType, status])
  @@index([shareToken])
  @@map("public_shares")
}

/// Sicherheitsprotokoll für abgewiesene oder manipulierte Freigabeversuche
model ShareSecurityLog {
  id String @id @default(uuid()) @db.Uuid

  userId   String? @map("user_id") @db.Uuid
  recipeId String? @map("recipe_id") @db.Uuid
  shareId  String? @map("share_id") @db.Uuid
  ipAddress String? @map("ip_address")
  action   String
  details  Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([recipeId])
  @@index([createdAt])
  @@map("share_security_logs")
}

// =============================================================================
// Berechtigungssystem — Gruppen, Katalog, granulare Rechte
// =============================================================================

enum PermissionEffect {
  ALLOW
  DENY
}

enum UserGroupStatus {
  active
  deactivated
  archived
}

enum PermissionAuditAction {
  group_created
  group_updated
  group_deleted
  group_duplicated
  group_archived
  group_deactivated
  group_member_added
  group_member_removed
  group_permission_allowed
  group_permission_denied
  group_permission_removed
  user_permission_allowed
  user_permission_denied
  user_permission_removed
  admin_right_granted
  admin_right_revoked
  superadmin_change_attempt
  unauthorized_access
  membership_group_sync
}

/// Zentraler Berechtigungskatalog (technische Schlüssel, nicht frei editierbar)
model Permission {
  id String @id @default(uuid()) @db.Uuid

  key         String  @unique
  name        String
  description String  @db.Text
  category    String
  areaKey     String? @map("area_key")
  actionKey   String? @map("action_key")
  isCritical  Boolean @default(false) @map("is_critical")
  superAdminOnly Boolean @default(false) @map("super_admin_only")
  isSystem    Boolean @default(true) @map("is_system")
  sortOrder   Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  groupPermissions UserGroupPermission[]
  userPermissions  UserPermission[]
  routePermissions RoutePermission[]
  featurePermissions FeaturePermission[]

  @@index([category])
  @@index([areaKey])
  @@map("permissions")
}

/// Administrierbare Benutzergruppe
model UserGroup {
  id String @id @default(uuid()) @db.Uuid

  name         String
  slug         String  @unique
  description  String? @db.Text
  internalNote String? @map("internal_note") @db.Text
  color        String? @default("#C9A227")
  priority     Int     @default(100)
  isSystem     Boolean @default(false) @map("is_system")
  status       UserGroupStatus @default(active)

  /// Automatische Zuordnung bei dieser Mitgliedschaftsrolle (null = manuelle Gruppe)
  linkedMembershipRole MembershipRole? @unique @map("linked_membership_role")
  /// Automatische Zuordnung bei dieser Systemrolle (null = keine)
  linkedSystemRole     UserSystemRole? @unique @map("linked_system_role")

  archivedAt DateTime? @map("archived_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  permissions UserGroupPermission[]
  members     UserGroupMember[]

  @@index([status])
  @@index([priority])
  @@map("user_groups")
}

/// Berechtigung einer Gruppe (ALLOW oder DENY)
model UserGroupPermission {
  id String @id @default(uuid()) @db.Uuid

  groupId      String @map("group_id") @db.Uuid
  group        UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  permissionId String @map("permission_id") @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  effect       PermissionEffect @default(ALLOW)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([groupId, permissionId])
  @@index([permissionId])
  @@map("user_group_permissions")
}

/// Benutzer-Zuordnung zu einer Gruppe (optional zeitlich begrenzt)
model UserGroupMember {
  id String @id @default(uuid()) @db.Uuid

  groupId String @map("group_id") @db.Uuid
  group   UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId  String @map("user_id") @db.Uuid
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  validFrom  DateTime? @map("valid_from")
  validUntil DateTime? @map("valid_until")
  isManual   Boolean   @default(true) @map("is_manual")

  assignedByUserId String? @map("assigned_by_user_id") @db.Uuid
  assignedBy       User?   @relation("UserGroupAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([groupId, userId])
  @@index([userId])
  @@index([validUntil])
  @@map("user_group_members")
}

/// Individuelle Benutzerberechtigung (Erlaubnis oder Verbot)
model UserPermission {
  id String @id @default(uuid()) @db.Uuid

  userId       String @map("user_id") @db.Uuid
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionId String @map("permission_id") @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  effect       PermissionEffect

  validFrom  DateTime? @map("valid_from")
  validUntil DateTime? @map("valid_until")

  assignedByUserId String? @map("assigned_by_user_id") @db.Uuid
  assignedBy       User?   @relation("UserPermissionAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, permissionId])
  @@index([permissionId])
  @@index([validUntil])
  @@map("user_permissions")
}

/// Route → Berechtigung (serverseitige URL-Prüfung)
model RoutePermission {
  id String @id @default(uuid()) @db.Uuid

  routeKey     String @unique @map("route_key")
  routePattern String @map("route_pattern")
  permissionId String @map("permission_id") @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([permissionId])
  @@map("route_permissions")
}

/// Feature-Schlüssel → Berechtigung
model FeaturePermission {
  id String @id @default(uuid()) @db.Uuid

  featureKey   String @unique @map("feature_key")
  permissionId String @map("permission_id") @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([permissionId])
  @@map("feature_permissions")
}

/// Audit-Protokoll für Gruppen- und Berechtigungsänderungen
model PermissionAuditLog {
  id String @id @default(uuid()) @db.Uuid

  action PermissionAuditAction

  actorUserId String? @map("actor_user_id") @db.Uuid
  actor       User?   @relation("PermissionAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  targetUserId String? @map("target_user_id") @db.Uuid
  targetUser   User?   @relation("PermissionAuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  targetGroupId String? @map("target_group_id") @db.Uuid
  targetGroupName String? @map("target_group_name")

  permissionKey String? @map("permission_key")
  previousValues Json? @map("previous_values")
  newValues      Json? @map("new_values")
  summary        String
  note           String? @db.Text
  ipAddress      String? @map("ip_address")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([targetGroupId])
  @@index([createdAt])
  @@index([action])
  @@map("permission_audit_logs")
}

// ─── Werkstatt: Produktempfehlungen & Partnerlinks ───────────────────────────

enum ProductRecommendationStatus {
  draft
  published
  archived
}

enum PartnerProgramType {
  amazon
  awin
  digistore24
  own_shop
  external
  course
}

enum ProductRecommendationClickType {
  view
  amazon
  shop
  affiliate
}

/// Partnerprogramm (zentral administrierbar, z. B. Amazon PartnerNet)
model PartnerProgram {
  id String @id @default(uuid()) @db.Uuid

  name        String
  slug        String @unique
  programType PartnerProgramType @map("program_type")
  affiliateId String? @map("affiliate_id")
  /// URL-Vorlage mit Platzhaltern: {asin}, {url}, {tag}
  urlTemplate String? @map("url_template") @db.Text
  baseUrl     String? @map("base_url")
  isActive    Boolean @default(true) @map("is_active")
  sortOrder   Int     @default(100) @map("sort_order")
  note        String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products ProductRecommendation[]

  @@index([isActive])
  @@map("partner_programs")
}

/// Globale Einstellungen für Produktempfehlungen (Singleton)
model ProductRecommendationSettings {
  id String @id @default("default")

  affiliateDisclosureText String @default("Dieser Link kann ein Partnerlink sein. Für Sie entstehen keine zusätzlichen Kosten.") @map("affiliate_disclosure_text") @db.Text
  defaultAmazonProgramId String? @map("default_amazon_program_id") @db.Uuid

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("product_recommendation_settings")
}

/// Produktkategorie (Wurstfüller, Thermometer, …)
model ProductRecommendationCategory {
  id String @id @default(uuid()) @db.Uuid

  name        String
  slug        String @unique
  description String? @db.Text
  sortOrder   Int     @default(100) @map("sort_order")
  isActive    Boolean @default(true) @map("is_active")
  /// Standardbild wenn Produkt kein eigenes Bild hat
  placeholderImageStorageKey String? @map("placeholder_image_storage_key")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products ProductRecommendation[]

  @@index([isActive])
  @@index([sortOrder])
  @@map("product_recommendation_categories")
}

/// Kuratierte Produktempfehlung in der Werkstatt
model ProductRecommendation {
  id String @id @default(uuid()) @db.Uuid

  title            String
  slug             String @unique
  shortDescription String @map("short_description") @db.VarChar(250)
  longDescription  String? @map("long_description") @db.Text
  manufacturer     String?
  subcategory      String?

  categoryId String @map("category_id") @db.Uuid
  category   ProductRecommendationCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  mainImageStorageKey String? @map("main_image_storage_key")
  sortOrder           Int     @default(100) @map("sort_order")
  priority            Int     @default(0)
  status              ProductRecommendationStatus @default(draft)

  /// Generischer Affiliate-Link (falls kein Partnerprogramm)
  affiliateLink String? @map("affiliate_link")
  /// Amazon ASIN oder vollständige URL
  amazonLink    String? @map("amazon_link")
  shopLink      String? @map("shop_link")

  partnerProgramId String? @map("partner_program_id") @db.Uuid
  partnerProgram   PartnerProgram? @relation(fields: [partnerProgramId], references: [id], onDelete: SetNull)

  /// Empfehlung von Fleischermeister Ralf Hermanski
  isMasterRecommendation Boolean @default(false) @map("is_master_recommendation")
  masterRecommendationText String? @map("master_recommendation_text") @db.Text

  seoTitle       String? @map("seo_title")
  seoDescription String? @map("seo_description") @db.VarChar(320)
  ogTitle        String? @map("og_title")
  ogDescription  String? @map("og_description") @db.VarChar(320)
  ogImageStorageKey String? @map("og_image_storage_key")

  viewCount          Int @default(0) @map("view_count")
  amazonClickCount   Int @default(0) @map("amazon_click_count")
  shopClickCount     Int @default(0) @map("shop_click_count")
  affiliateClickCount Int @default(0) @map("affiliate_click_count")

  publishedAt DateTime? @map("published_at")
  archivedAt  DateTime? @map("archived_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  galleryImages ProductRecommendationGalleryImage[]
  courseLinks   ProductRecommendationCourseLink[]
  recipeLinks   ProductRecommendationRecipeLink[]
  clickEvents   ProductRecommendationClickEvent[]

  @@index([status])
  @@index([categoryId])
  @@index([sortOrder])
  @@index([priority])
  @@map("product_recommendations")
}

/// Galeriebild eines Produkts
model ProductRecommendationGalleryImage {
  id String @id @default(uuid()) @db.Uuid

  productId String @map("product_id") @db.Uuid
  product   ProductRecommendation @relation(fields: [productId], references: [id], onDelete: Cascade)

  storageKey String @map("storage_key")
  sortOrder  Int    @default(100) @map("sort_order")
  caption    String?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@map("product_recommendation_gallery_images")
}

/// Verknüpfung Produktempfehlung ↔ Kurs
model ProductRecommendationCourseLink {
  id String @id @default(uuid()) @db.Uuid

  productId String @map("product_id") @db.Uuid
  product   ProductRecommendation @relation(fields: [productId], references: [id], onDelete: Cascade)
  courseId  String @map("course_id") @db.Uuid
  course    Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  sortOrder Int    @default(100) @map("sort_order")

  @@unique([productId, courseId])
  @@index([courseId])
  @@map("product_recommendation_course_links")
}

/// Verknüpfung Produktempfehlung ↔ Rezept
model ProductRecommendationRecipeLink {
  id String @id @default(uuid()) @db.Uuid

  productId String @map("product_id") @db.Uuid
  product   ProductRecommendation @relation(fields: [productId], references: [id], onDelete: Cascade)
  recipeId  String @map("recipe_id") @db.Uuid
  recipe    Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  sortOrder Int    @default(100) @map("sort_order")

  @@unique([productId, recipeId])
  @@index([recipeId])
  @@map("product_recommendation_recipe_links")
}

/// Klick-/Aufruf-Ereignis für Statistik
model ProductRecommendationClickEvent {
  id String @id @default(uuid()) @db.Uuid

  productId String @map("product_id") @db.Uuid
  product   ProductRecommendation @relation(fields: [productId], references: [id], onDelete: Cascade)

  eventType ProductRecommendationClickType @map("event_type")
  userId    String? @map("user_id") @db.Uuid
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@index([eventType])
  @@index([createdAt])
  @@map("product_recommendation_click_events")
}

// =============================================================================
// Enterprise Security — Ereignisse, Sperren, Audit, 2FA, Sitzungen
// =============================================================================

enum SecurityEventType {
  LOGIN_FAILED
  ADMIN_LOGIN_FAILED
  TOTP_FAILED
  TOTP_SUCCESS
  PASSWORD_RESET_REQUEST
  PASSWORD_RESET_ABUSE
  REGISTRATION_ATTEMPT
  REGISTRATION_SPAM
  API_ABUSE
  MASS_REQUEST
  BOT_ACTIVITY
  SUSPICIOUS_URL
  FORM_MANIPULATION
  RATE_LIMIT_EXCEEDED
  IP_BLOCKED
  IP_UNBLOCKED
  SESSION_REVOKED
  UPLOAD_REJECTED
  CAPTCHA_REQUIRED
  SECURITY_WARNING
}

enum SecurityRiskLevel {
  low
  medium
  high
  critical
}

enum IpBlockLevel {
  throttle
  captcha
  temporary_30m
  extended_24h
  permanent
}

enum SecurityAuditAction {
  ROLE_CHANGE
  USER_UPDATE
  USER_SUSPEND
  USER_UNSUSPEND
  MEMBERSHIP_CHANGE
  COURSE_ACCESS_GRANT
  COURSE_ACCESS_REVOKE
  CERTIFICATE_ISSUE
  CERTIFICATE_REVOKE
  PAYMENT_PROCESSED
  IP_BLOCK
  IP_UNBLOCK
  SETTINGS_CHANGE
  TOTP_ENABLED
  TOTP_DISABLED
  SESSION_REVOKED
  SECURITY_RULE_CHANGE
  PERMISSION_CHANGE
  OTHER
}

enum SecurityAuditResult {
  success
  failure
  denied
}

/// Sicherheitsereignis (Angriffserkennung, Fehlversuche, Missbrauch)
model SecurityEvent {
  id String @id @default(uuid()) @db.Uuid

  eventType SecurityEventType @map("event_type")
  riskLevel SecurityRiskLevel @default(low) @map("risk_level")

  ipAddress   String? @map("ip_address")
  userAgent   String? @map("user_agent") @db.Text
  browser     String?
  os          String?
  countryCode String? @map("country_code")
  region      String?
  asn         String?
  provider    String?

  userId String? @map("user_id") @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  path        String?
  method      String?
  description String? @db.Text
  metadata    Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([eventType])
  @@index([riskLevel])
  @@index([ipAddress])
  @@index([userId])
  @@index([createdAt])
  @@index([countryCode])
  @@map("security_events")
}

/// IP-Sperre (stufenweise: throttle → captcha → 30m → 24h → permanent)
model BlockedIp {
  id String @id @default(uuid()) @db.Uuid

  ipAddress String @map("ip_address")
  level     IpBlockLevel @default(temporary_30m)
  reason    String? @db.Text
  notes     String? @db.Text

  blockedAt DateTime  @default(now()) @map("blocked_at")
  expiresAt DateTime? @map("expires_at")

  createdByUserId String? @map("created_by_user_id") @db.Uuid
  createdByUser   User?   @relation("BlockedIpCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  isActive  Boolean  @default(true) @map("is_active")
  revokedAt DateTime? @map("revoked_at")

  @@index([ipAddress])
  @@index([isActive])
  @@index([expiresAt])
  @@map("blocked_ips")
}

/// Unveränderliches Administrator-Sicherheitsprotokoll
model SecurityAuditLog {
  id String @id @default(uuid()) @db.Uuid

  action     SecurityAuditAction
  result     SecurityAuditResult @default(success)
  entityType String? @map("entity_type")
  entityId   String? @map("entity_id") @db.Uuid

  actorUserId String? @map("actor_user_id") @db.Uuid
  actorUser   User?   @relation("SecurityAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  targetUserId String? @map("target_user_id") @db.Uuid
  targetUser   User?   @relation("SecurityAuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  ipAddress   String? @map("ip_address")
  description String? @db.Text
  metadata    Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([action])
  @@index([actorUserId])
  @@index([targetUserId])
  @@index([createdAt])
  @@map("security_audit_logs")
}

/// Registrierte Nutzersitzung (Geräteverwaltung, Widerruf)
model UserSession {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String @map("token_hash")

  deviceLabel String? @map("device_label")
  browser     String?
  os          String?
  countryCode String? @map("country_code")
  region      String?
  ipAddress   String? @map("ip_address")

  lastActiveAt DateTime @default(now()) @map("last_active_at")
  createdAt    DateTime @default(now()) @map("created_at")
  revokedAt    DateTime? @map("revoked_at")

  isNewDevice Boolean @default(false) @map("is_new_device")

  @@index([userId])
  @@index([tokenHash])
  @@index([revokedAt])
  @@map("user_sessions")
}

/// TOTP-Zwei-Faktor-Authentifizierung (Google Authenticator kompatibel)
model UserTotp {
  id String @id @default(uuid()) @db.Uuid

  userId String @unique @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Verschlüsselter/gehashter Secret (nur serverseitig)
  secretEncrypted String @map("secret_encrypted")

  isEnabled   Boolean  @default(false) @map("is_enabled")
  enabledAt   DateTime? @map("enabled_at")
  lastUsedAt  DateTime? @map("last_used_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("user_totp")
}

/// Einmal-Backup-Codes für 2FA-Wiederherstellung
model TotpBackupCode {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  codeHash String @map("code_hash")
  usedAt   DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([codeHash])
  @@map("totp_backup_codes")
}

/// Verdächtiger Nutzer (Flag für Admin-Review)
model SuspiciousUserFlag {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  reason    String @db.Text
  riskLevel SecurityRiskLevel @default(medium) @map("risk_level")
  isActive  Boolean @default(true) @map("is_active")
  notes     String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  resolvedAt DateTime? @map("resolved_at")

  @@index([userId])
  @@index([isActive])
  @@map("suspicious_user_flags")
}

/// Globale Sicherheitseinstellungen (Singleton)
model SecuritySettings {
  id String @id @default("default") @db.VarChar(32)

  /// Stufe 1: Fehlversuche bis Verlangsamung
  loginFailThresholdThrottle Int @default(5) @map("login_fail_threshold_throttle")
  /// Stufe 1b: Fehlversuche bis Captcha
  loginFailThresholdCaptcha Int @default(8) @map("login_fail_threshold_captcha")
  /// Stufe 2: Fehlversuche bis 30-Min-Sperre
  loginFailThreshold30m Int @default(10) @map("login_fail_threshold_30m")
  /// Stufe 3: Fehlversuche bis 24h-Sperre
  loginFailThreshold24h Int @default(15) @map("login_fail_threshold_24h")

  /// Rate-Limits (pro Minute)
  loginRateLimitPerIp      Int @default(20) @map("login_rate_limit_per_ip")
  registerRateLimitPerIp   Int @default(5) @map("register_rate_limit_per_ip")
  passwordResetRateLimitPerIp Int @default(5) @map("password_reset_rate_limit_per_ip")
  apiRateLimitPerIp        Int @default(120) @map("api_rate_limit_per_ip")

  /// DSGVO-Aufbewahrungsfristen (Tage)
  retentionLoginAttemptsDays Int @default(90) @map("retention_login_attempts_days")
  retentionSecurityEventsDays Int @default(365) @map("retention_security_events_days")
  retentionBlockedIpsDays    Int @default(180) @map("retention_blocked_ips_days")
  retentionAuditLogDays      Int @default(730) @map("retention_audit_log_days")

  /// 2FA-Pflicht für Rollen (JSON-Array von UserSystemRole)
  totpRequiredRoles Json @default("[\"ADMIN\",\"SUPERADMIN\",\"SUPPORT\",\"INSTRUCTOR\"]") @map("totp_required_roles")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("security_settings")
}

// -----------------------------------------------------------------------------
// Betatest — Einladungen und Tester-Aufträge
// -----------------------------------------------------------------------------

enum BetaInviteStatus {
  PENDING
  SENT
  ACCEPTED
  EXPIRED
  REVOKED
}

enum BetaTaskStatus {
  OPEN
  COMPLETED
}

model BetaInvite {
  id String @id @default(uuid()) @db.Uuid

  email     String
  emailNorm String @map("email_norm")

  tokenHash String @unique @map("token_hash")

  invitedById String @map("invited_by_id") @db.Uuid
  invitedBy   User   @relation("BetaInvitesSent", fields: [invitedById], references: [id], onDelete: Restrict)

  userId String? @map("user_id") @db.Uuid
  user   User?   @relation("BetaInvitesAccepted", fields: [userId], references: [id], onDelete: SetNull)

  status BetaInviteStatus @default(PENDING)

  personalMessage String? @map("personal_message") @db.Text

  expiresAt  DateTime  @map("expires_at")
  sentAt     DateTime? @map("sent_at")
  acceptedAt DateTime? @map("accepted_at")
  revokedAt  DateTime? @map("revoked_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tasks BetaTesterTask[]

  @@index([emailNorm])
  @@index([status])
  @@index([userId])
  @@map("beta_invites")
}

model BetaTesterTask {
  id String @id @default(uuid()) @db.Uuid

  inviteId String?     @map("invite_id") @db.Uuid
  invite   BetaInvite? @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  userId String? @map("user_id") @db.Uuid
  user   User?   @relation("BetaTesterTasks", fields: [userId], references: [id], onDelete: Cascade)

  assignedById String @map("assigned_by_id") @db.Uuid
  assignedBy   User   @relation("BetaTasksAssigned", fields: [assignedById], references: [id], onDelete: Restrict)

  title       String
  description String? @db.Text

  status BetaTaskStatus @default(OPEN)

  sortOrder Int @default(0) @map("sort_order")

  dueAt       DateTime? @map("due_at")
  completedAt DateTime? @map("completed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, status])
  @@index([inviteId])
  @@map("beta_tester_tasks")
}
