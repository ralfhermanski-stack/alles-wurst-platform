  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([pageType])
  @@index([generationStatus])
  @@index([seoSource])
  @@map("page_seo")
}

model PageSeoSettings {
  id String @id @default("default")

  autoGenerateEnabled Boolean @default(true) @map("auto_generate_enabled")
  autoUpdateOnChange  Boolean @default(true) @map("auto_update_on_change")
  onlyPublishedPages  Boolean @default(true) @map("only_published_pages")
  maxApiCallsPerDay   Int     @default(50) @map("max_api_calls_per_day")
  apiCallsToday       Int     @default(0) @map("api_calls_today")
  apiCallsResetAt     DateTime? @map("api_calls_reset_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("page_seo_settings")
}

model PageSeoQueueJob {
  id String @id @default(cuid())

  routeKey String @map("route_key")
  action   String @default("generate")
  priority Int    @default(0)
  status   String @default("pending")

  attempts    Int @default(0)
  maxAttempts Int @default(3) @map("max_attempts")
  errorMessage String? @map("error_message") @db.Text

  scheduledAt DateTime @default(now()) @map("scheduled_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([status, scheduledAt])
  @@index([routeKey])
  @@map("page_seo_queue_jobs")
}

