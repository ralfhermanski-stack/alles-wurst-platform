// =============================================================================
// Platform Text Management — zentrale UI-/System-Texte
// =============================================================================

enum PlatformTextFormat {
  plain
  markdown
  html
}

enum PlatformTextStatus {
  standard
  draft
  published
  archived
}

/// Zentral verwalteter Plattformtext (Key = eindeutiger Schlüssel)
model PlatformText {
  key            String             @id
  category       String
  locale         String             @default("de")
  value          String             @db.Text
  defaultValue   String             @map("default_value") @db.Text
  draftValue     String?            @map("draft_value") @db.Text
  status         PlatformTextStatus @default(published)
  publishedAt    DateTime?          @map("published_at")
  publishedBy    String?            @map("published_by") @db.Uuid
  pagePath       String?            @map("page_path")
  contentType    String             @default("text") @map("content_type")
  maxLength      Int?               @map("max_length")
  allowRichText  Boolean            @default(false) @map("allow_rich_text")
  label          String?
  description    String?            @db.Text
  format         PlatformTextFormat @default(plain)
  version        Int                @default(1)
  updatedBy      String?            @map("updated_by") @db.Uuid
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  versions PlatformTextVersion[]
  changes  PlatformTextChangeLog[]
  elements EditablePageElement[]

  @@index([category])
  @@index([locale])
  @@index([pagePath])
  @@index([status])
  @@map("platform_texts")
}

/// Versionierung — Snapshot bei jeder Änderung
model PlatformTextVersion {
  id         String   @id @default(uuid()) @db.Uuid
  textKey    String   @map("text_key")
  version    Int
  value      String   @db.Text
  changedBy  String?  @map("changed_by") @db.Uuid
  changeNote String?  @map("change_note")
  createdAt  DateTime @default(now()) @map("created_at")

  text PlatformText @relation(fields: [textKey], references: [key], onDelete: Cascade)

  @@unique([textKey, version])
  @@index([textKey])
  @@map("platform_text_versions")
}

/// Änderungsprotokoll
model PlatformTextChangeLog {
  id        String   @id @default(uuid()) @db.Uuid
  textKey   String   @map("text_key")
  action    String
  oldValue  String?  @map("old_value") @db.Text
  newValue  String?  @map("new_value") @db.Text
  userId    String?  @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  text PlatformText @relation(fields: [textKey], references: [key], onDelete: Cascade)

  @@index([textKey])
  @@index([createdAt])
  @@map("platform_text_change_logs")
}

/// Registrierte bearbeitbare Seite im visuellen Editor
model EditablePage {
  id        String   @id
  name      String
  path      String
  category  String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  elements  EditablePageElement[]
  releases  PageContentRelease[]
  sessions  PageEditorSession[]

  @@index([category])
  @@index([path])
  @@map("editable_pages")
}

/// Zuordnung Textschlüssel → Seite + Elementtyp
model EditablePageElement {
  id          String  @id @default(uuid()) @db.Uuid
  pageId      String  @map("page_id")
  textKey     String  @map("text_key")
  elementType String  @default("text") @map("element_type")
  label       String
  sortOrder   Int     @default(0) @map("sort_order")
  enabled     Boolean @default(true)

  page EditablePage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  text PlatformText @relation(fields: [textKey], references: [key], onDelete: Cascade)

  @@unique([pageId, textKey])
  @@index([pageId])
  @@map("editable_page_elements")
}

/// Veröffentlichungs-Lauf für eine Seite
model PageContentRelease {
  id          String   @id @default(uuid()) @db.Uuid
  pageId      String   @map("page_id")
  version     Int      @default(1)
  status      String   @default("published")
  createdBy   String?  @map("created_by") @db.Uuid
  publishedBy String?  @map("published_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  publishedAt DateTime? @map("published_at")

  page EditablePage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@map("page_content_releases")
}

/// Kurzlebige Editor-Vorschau-Session (signiert)
model PageEditorSession {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  pageId    String   @map("page_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  page EditablePage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("page_editor_sessions")
}

