  internalLinks    Json @default("[]") @map("internal_links")
  relatedPostIds   Json @default("[]") @map("related_post_ids")
  linkedCourseIds  Json @default("[]") @map("linked_course_ids")
  linkedRecipeIds  Json @default("[]") @map("linked_recipe_ids")
  ctaConfig        Json @default("{}") @map("cta_config")

  reviewedByName String? @default("Ralf Hermanski, Fleischermeister") @map("reviewed_by_name")
  expertNote     String? @map("expert_note") @db.Text
  sourcesNote    String? @map("sources_note") @db.Text
  disclaimerNote String? @default("Diese Inhalte dienen der allgemeinen Information und ersetzen keine individuelle Lebensmittelkontrolle oder Rechtsberatung.") @map("disclaimer_note") @db.Text

  readingTimeMinutes Int @default(0) @map("reading_time_minutes")
  viewCount          Int @default(0) @map("view_count")

  robotsIndex  Boolean @default(true) @map("robots_index")
  robotsFollow Boolean @default(true) @map("robots_follow")

  ogTitle            String? @map("og_title")
  ogDescription      String? @map("og_description") @db.Text
  twitterTitle       String? @map("twitter_title")
  twitterDescription String? @map("twitter_description") @db.Text
  seoKeywords        Json    @default("[]") @map("seo_keywords")
  seoTagsSuggested   Json    @default("[]") @map("seo_tags_suggested")
  schemaJson         Json?   @map("schema_json")
  internalLinkSuggestions Json @default("[]") @map("internal_link_suggestions")
  seoScore           Int?    @map("seo_score")
  readabilityScore   Int?    @map("readability_score")
  lastSeoAnalysisAt  DateTime? @map("last_seo_analysis_at")
  seoAnalysisDraft   Json?   @map("seo_analysis_draft")

  publishedAt    DateTime? @map("published_at")
  scheduledAt    DateTime? @map("scheduled_at")
  contentUpdatedAt DateTime? @map("content_updated_at")
  lastReviewedAt DateTime? @map("last_reviewed_at")

  tags   BlogPostTag[]
  topics BlogPostTopic[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([authorUserId])
  @@index([scheduledAt])
  @@map("blog_posts")
}

// -----------------------------------------------------------------------------
// Site-weites automatisches SEO (öffentliche Seiten, nicht Blog-Artikel)
