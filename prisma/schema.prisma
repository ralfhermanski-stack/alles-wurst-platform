// ── Social Media ─────────────────────────────────────────────────────────────

enum SocialMediaPlatform {
  TIKTOK
  INSTAGRAM
  FACEBOOK
  YOUTUBE
}

enum SocialMediaIntegrationMode {
  API
  EMBED
  MANUAL
  DISABLED
}

enum SocialMediaPostSource {
  API
  MANUAL
}

enum SocialMediaPostType {
  IMAGE
  VIDEO
  REEL
  SHORT
  POST
  LIVE
  CAROUSEL
}

enum SocialMediaConnectionStatus {
  NOT_CONFIGURED
  CONNECTED
  TOKEN_EXPIRED
  ERROR
  DISABLED
}

enum SocialMediaSyncStatus {
  RUNNING
  SUCCESS
  WARNING
  FAILED
}

enum SocialMediaTagSource {
  AUTO
  MANUAL
  MIXED
}

model SocialMediaChannel {
  id String @id @default(uuid()) @db.Uuid

  platform           SocialMediaPlatform
  name               String
  publicName         String?  @map("public_name")
  handle             String?
  profileUrl         String?  @map("profile_url")
  externalChannelId  String?  @map("external_channel_id")
  description        String?
  icon               String?
  coverImageUrl      String?  @map("cover_image_url")

  active             Boolean  @default(true)
  showOnHomepage     Boolean  @default(true) @map("show_on_homepage")
  displayOrder       Int      @default(0) @map("display_order")

  integrationMode    SocialMediaIntegrationMode @default(MANUAL) @map("integration_mode")
  connectionStatus   SocialMediaConnectionStatus @default(NOT_CONFIGURED) @map("connection_status")

  ctaLabel           String?  @map("cta_label")
  ctaUrl             String?  @map("cta_url")

  followerCount          Int?     @map("follower_count")
  followerCountUpdatedAt DateTime? @map("follower_count_updated_at")
  showFollowerCount      Boolean  @default(false) @map("show_follower_count")

  channelKeywords    String[] @default([]) @map("channel_keywords")
  tagSource          SocialMediaTagSource @default(AUTO) @map("tag_source")
  manualTags         String[] @default([]) @map("manual_tags")

  featuredPostId     String? @map("featured_post_id") @db.Uuid

  lastSyncedAt       DateTime? @map("last_synced_at")
  lastErrorAt        DateTime? @map("last_error_at")
  lastErrorMessage   String?   @map("last_error_message")

  syncIntervalMinutes Int @default(120) @map("sync_interval_minutes")

  isTestData Boolean @default(false) @map("is_test_data")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  credentials SocialMediaCredential[]
  posts       SocialMediaPost[]
  syncLogs    SocialMediaSyncLog[]
  featuredPost SocialMediaPost? @relation("FeaturedPost", fields: [featuredPostId], references: [id], onDelete: SetNull)

  @@unique([platform, externalChannelId])
  @@index([active, showOnHomepage, displayOrder])
  @@map("social_media_channels")
}

model SocialMediaCredential {
  id String @id @default(uuid()) @db.Uuid

  channelId       String @map("channel_id") @db.Uuid
  channel         SocialMediaChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  credentialType  String @map("credential_type")
  encryptedValue  String @map("encrypted_value")
  expiresAt       DateTime? @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([channelId, credentialType])
  @@map("social_media_credentials")
}

model SocialMediaPost {
  id String @id @default(uuid()) @db.Uuid

  channelId   String @map("channel_id") @db.Uuid
  channel     SocialMediaChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  externalId  String? @map("external_id")
  sourceType  SocialMediaPostSource @default(MANUAL) @map("source_type")
  postType    SocialMediaPostType   @default(POST) @map("post_type")

  title         String?
  content       String?
  thumbnailUrl  String? @map("thumbnail_url")
  localThumbnailUrl String? @map("local_thumbnail_url")
  mediaUrl      String? @map("media_url")
  permalink     String?
  tags          String[] @default([])

  publishedAt DateTime? @map("published_at")
  importedAt  DateTime  @default(now()) @map("imported_at")

  active          Boolean @default(true)
  featured        Boolean @default(false)
  showOnHomepage  Boolean @default(false) @map("show_on_homepage")
  displayOrder    Int     @default(0) @map("display_order")

  isManualLocked  Boolean @default(false) @map("is_manual_locked")
  isUnavailable   Boolean @default(false) @map("is_unavailable")
  isTestData      Boolean @default(false) @map("is_test_data")

  rawMetadata Json? @map("raw_metadata")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  featuredForChannels SocialMediaChannel[] @relation("FeaturedPost")

  @@unique([channelId, externalId])
  @@index([channelId, active, showOnHomepage])
  @@index([publishedAt])
  @@map("social_media_posts")
}

model SocialMediaSyncLog {
  id String @id @default(uuid()) @db.Uuid

  channelId String? @map("channel_id") @db.Uuid
  channel   SocialMediaChannel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  platform  SocialMediaPlatform?

  status        SocialMediaSyncStatus
  startedAt     DateTime @default(now()) @map("started_at")
  finishedAt    DateTime? @map("finished_at")

  foundCount    Int @default(0) @map("found_count")
  createdCount  Int @default(0) @map("created_count")
  updatedCount  Int @default(0) @map("updated_count")
  skippedCount  Int @default(0) @map("skipped_count")

  errorCode     String? @map("error_code")
  errorMessage  String? @map("error_message")

  triggeredBy         String @default("cron") @map("triggered_by")
  triggeredByUserId   String? @map("triggered_by_user_id") @db.Uuid

  @@index([startedAt])
  @@index([platform, status])
  @@map("social_media_sync_logs")
}

// ── Community Challenges ─────────────────────────────────────────────────────

enum CommunityChallengeStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  VOTING
  COMPLETED
  ARCHIVED
}

enum ChallengeSubmissionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  WITHDRAWN
  WINNER
}

enum ChallengeVotingMode {
  ADMIN_ONLY
  JURY
  COMMUNITY
  MIXED
}

enum ChallengePopupState {
  SEEN
  REMIND_LATER
  DISMISSED
  PARTICIPATING
  SUBMITTED
}

enum ChallengeNotificationType {
  PUBLISHED
  ENDS_IN_7_DAYS
  ENDS_IN_2_DAYS
  DRAFT_REMINDER
  SUBMITTED
  APPROVED
  REJECTED
  WINNER_ANNOUNCED
}

model CommunityChallenge {
  id String @id @default(uuid()) @db.Uuid

  title       String
  slug        String @unique
  excerpt     String?
  description String
  task        String

  coverImageUrl String? @map("cover_image_url")

  startAt             DateTime @map("start_at")
  endAt               DateTime @map("end_at")
  submissionDeadline  DateTime @map("submission_deadline")
  votingStartAt       DateTime? @map("voting_start_at")
  votingEndAt         DateTime? @map("voting_end_at")

  status CommunityChallengeStatus @default(DRAFT)

  eligibilityConfig   Json @default("{}") @map("eligibility_config")
  participationRules  String? @map("participation_rules")
  submissionConfig    Json @default("{}") @map("submission_config")

  votingMode      ChallengeVotingMode @default(ADMIN_ONLY) @map("voting_mode")
  winnerCount     Int @default(1) @map("winner_count")
  prizeDescription String? @map("prize_description")

  showOnHomepage        Boolean @default(true) @map("show_on_homepage")
  showInMemberDashboard Boolean @default(true) @map("show_in_member_dashboard")

  popupEnabled  Boolean @default(false) @map("popup_enabled")
  popupStartAt  DateTime? @map("popup_start_at")
  popupEndAt    DateTime? @map("popup_end_at")
  popupRemindAfterDays Int @default(3) @map("popup_remind_after_days")

  notificationsEnabled Boolean @default(true) @map("notifications_enabled")

  forumId String? @map("forum_id") @db.Uuid
  forum   Forum?  @relation(fields: [forumId], references: [id], onDelete: SetNull)
  forumThreadId String? @map("forum_thread_id") @db.Uuid

  createdById  String? @map("created_by_id") @db.Uuid
  publishedById String? @map("published_by_id") @db.Uuid
  publishedAt   DateTime? @map("published_at")

  isTestData Boolean @default(false) @map("is_test_data")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  submissions      ChallengeSubmission[]
  votes            ChallengeVote[]
  userStates       ChallengeUserState[]
  notificationLogs ChallengeNotificationLog[]

  @@index([status, startAt])
  @@index([showOnHomepage, status])
  @@map("community_challenges")
}

model ChallengeSubmission {
  id String @id @default(uuid()) @db.Uuid

  challengeId String @map("challenge_id") @db.Uuid
  challenge   CommunityChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId      String @map("user_id") @db.Uuid
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title           String
  description     String
  recipeContent   String? @map("recipe_content")
  videoUrl        String? @map("video_url")

  status ChallengeSubmissionStatus @default(DRAFT)

  publicConsent       Boolean @default(false) @map("public_consent")
  mediaRightsConsent  Boolean @default(false) @map("media_rights_consent")
  mediaRightsConsentAt DateTime? @map("media_rights_consent_at")

  submittedAt  DateTime? @map("submitted_at")
  reviewedAt   DateTime? @map("reviewed_at")
  reviewedById String?   @map("reviewed_by_id") @db.Uuid
  rejectionReason String? @map("rejection_reason")

  isWinner   Boolean @default(false) @map("is_winner")
  winnerRank Int?    @map("winner_rank")
  voteCount  Int     @default(0) @map("vote_count")

  isTestData Boolean @default(false) @map("is_test_data")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  media ChallengeSubmissionMedia[]
  votes ChallengeVote[]

  @@unique([challengeId, userId])
  @@index([challengeId, status])
  @@index([userId])
  @@map("challenge_submissions")
}

model ChallengeSubmissionMedia {
  id String @id @default(uuid()) @db.Uuid

  submissionId String @map("submission_id") @db.Uuid
  submission   ChallengeSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  storageUrl  String @map("storage_url")
  storageKey  String @map("storage_key")
  mimeType    String @map("mime_type")
  sizeBytes   Int    @map("size_bytes")
  mediaType   String @default("image") @map("media_type")
  displayOrder Int   @default(0) @map("display_order")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([submissionId])
  @@map("challenge_submission_media")
}

model ChallengeVote {
  id String @id @default(uuid()) @db.Uuid

  challengeId  String @map("challenge_id") @db.Uuid
  challenge    CommunityChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  submissionId String @map("submission_id") @db.Uuid
  submission   ChallengeSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  userId       String @map("user_id") @db.Uuid
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([challengeId, userId, submissionId])
  @@index([submissionId])
  @@map("challenge_votes")
}

model ChallengeUserState {
  id String @id @default(uuid()) @db.Uuid

  challengeId String @map("challenge_id") @db.Uuid
  challenge   CommunityChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId      String @map("user_id") @db.Uuid
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  popupState   ChallengePopupState? @map("popup_state")
  lastPopupAt  DateTime? @map("last_popup_at")
  firstSeenAt  DateTime? @map("first_seen_at")
  dismissedAt  DateTime? @map("dismissed_at")
  reminderAt   DateTime? @map("reminder_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([challengeId, userId])
  @@map("challenge_user_states")
}

model ChallengeNotificationLog {
  id String @id @default(uuid()) @db.Uuid

  challengeId      String @map("challenge_id") @db.Uuid
  challenge        CommunityChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId           String @map("user_id") @db.Uuid
  user             User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  notificationType ChallengeNotificationType @map("notification_type")

  sentAt DateTime @default(now()) @map("sent_at")

  @@unique([challengeId, userId, notificationType])
  @@index([userId])
  @@map("challenge_notification_logs")
}

// =============================================================================
// Rechtstexte & Widerruf
