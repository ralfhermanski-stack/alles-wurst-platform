  general
  membership
}

enum ForumReadAccess {
  public
  registered
  course_access
  membership
  mini_course_access
}

enum ForumPurpose {
  introduction
  qa
  improvements
  custom
}

/// Bewertung eines Kurses durch einen Teilnehmer
model CourseReview {
  id String @id @default(uuid()) @db.Uuid

  courseId String @map("course_id") @db.Uuid
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rating     Int
  reviewText String? @db.Text @map("review_text")
  status     CourseReviewStatus @default(pending)

  displayNameSnapshot String? @map("display_name_snapshot")
  avatarUrlSnapshot   String? @map("avatar_url_snapshot")

  featuredOnHomepage      Boolean @default(false) @map("featured_on_homepage")
  showMembershipSnapshot  Boolean @default(false) @map("show_membership_snapshot")
  membershipLabelSnapshot String? @map("membership_label_snapshot")
  courseTitleSnapshot     String? @map("course_title_snapshot")

  reviewedAt      DateTime? @map("reviewed_at")
  reviewedById    String?   @map("reviewed_by_id") @db.Uuid
